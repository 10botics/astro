---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import CTAButton from '../../components/CTAButton.astro';
import RelatedNews from '../../components/course/RelatedNews.astro';
import {
  discoverStaffDevelopmentCourses,
  generateTagSlug,
  AUDIENCE_TAG_MAPPING,
} from '../../utils/courseMappings';
import type { Course } from '../../utils/courseMappings';
import heroImage from '../../assets/images/staff-development-day/mainpage/hero-image.jpeg';
import heroBackground from '../../assets/images/staff-development-day/mainpage/hero-background.jpeg';
import gallery1 from '../../assets/images/staff-development-day/mainpage/gallery-1.jpeg';
import gallery2 from '../../assets/images/staff-development-day/mainpage/gallery-2.jpeg';
import gallery3 from '../../assets/images/staff-development-day/mainpage/gallery-3.jpeg';
import gallery4 from '../../assets/images/staff-development-day/mainpage/gallery-4.jpeg';

const astroWorkshops = await discoverStaffDevelopmentCourses(['index.astro', '[slug].astro']);

const sortedWorkshops = astroWorkshops.sort(
  (a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime()
);

const pageTitle = '教師發展日工作坊 - 10教育';
const pageDescription =
  '定期舉辦教師STEM培訓工作坊，提供AIGC技術協助自動生成教案試題學習資料，節省教師時間精力，獲取整理教學資源使教學流暢高效';
const pageKeywords =
  '教師發展日, 教師培訓, STEM工作坊, ChatGPT, AI教育, Raspberry Pi, Donkey Car, Gemini, 10教育';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  ogImage={heroImage.src}
>
  <main class="courses-index">
    <header class="relative text-white py-20 overflow-hidden">
      <div class="absolute inset-0">
        <Image
          src={heroBackground}
          alt="教師發展日背景"
          class="w-full h-full object-cover"
          width={1920}
          height={1080}
        />
        <div class="absolute inset-0 bg-black bg-opacity-30"></div>
      </div>

      <div class="container mx-auto px-4 relative z-10">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            教師發展日<br />
            <span class="text-gray-200">Staff Development Day</span>
          </h1>
          <p class="text-xl md:text-2xl text-gray-100 leading-relaxed">
            10Botics 定期舉辦教師工作坊，為教師提供STEM培訓<br />
          </p>
        </div>
      </div>
    </header>

    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto mb-12 text-center">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">工作坊及講座</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            瀏覽我們為教師設計的培訓主題，點選標籤可按主題篩選相關工作坊。
          </p>
        </div>
        <div class="max-w-6xl mx-auto">
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {sortedWorkshops.map((workshop: Course) => (
              <article class="course-card bg-white rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden">
                {workshop.heroImage && (
                  <div class="course-image-container bg-gray-100 overflow-hidden aspect-video">
                    {typeof workshop.heroImage === 'string' ? (
                      <Image
                        src={workshop.heroImage}
                        alt={workshop.title}
                        width={600}
                        height={400}
                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                      />
                    ) : (
                      <Image
                        src={workshop.heroImage}
                        alt={workshop.title}
                        width={600}
                        height={400}
                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                      />
                    )}
                  </div>
                )}
                <div class="p-6">
                  <div class="mb-4">
                    <h3 class="text-xl font-bold mb-2 text-gray-800 line-clamp-2">
                      <a
                        href={`/staff-development-day/${workshop.slug}`}
                        class="hover:text-brand-blue-600 transition-colors"
                      >
                        {workshop.title}
                      </a>
                    </h3>

                    {workshop.description && (
                      <p class="text-gray-600 text-sm line-clamp-3 mb-4">{workshop.description}</p>
                    )}
                  </div>

                  <div class="mb-4">
                    {(() => {
                      const targetAudienceTags = ['初小', '高小', '初中', '高中'];
                      const otherTags = workshop.tags.filter((tag) => !targetAudienceTags.includes(tag));
                      const audienceTags = workshop.tags.filter((tag) => targetAudienceTags.includes(tag));

                      return (
                        <div class="space-y-2">
                          {audienceTags.length > 0 && (
                            <div class="flex flex-wrap gap-1 items-center">
                              <span class="text-xs font-medium text-gray-600 mr-1">適合對象:</span>
                              {audienceTags.map((tag) => {
                                const tagSlug =
                                  AUDIENCE_TAG_MAPPING[tag] || tag.toLowerCase().replace(/\s+/g, '-');
                                return (
                                  <a
                                    href={`/staff-development-day/tag/${tagSlug}`}
                                    class="bg-cyan-100 text-cyan-800 px-2 py-1 rounded text-xs font-medium hover:bg-cyan-200 transition-colors"
                                  >
                                    {tag}
                                  </a>
                                );
                              })}
                            </div>
                          )}

                          {otherTags.length > 0 && (
                            <div class="flex flex-wrap gap-1">
                              {otherTags.map((tag) => {
                                const tagSlug = generateTagSlug(tag);
                                return (
                                  <a
                                    href={`/staff-development-day/tag/${tagSlug}`}
                                    class="bg-brand-blue-100 text-brand-blue-800 px-2 py-1 rounded text-xs font-medium hover:bg-brand-blue-200 transition-colors"
                                  >
                                    {tag}
                                  </a>
                                );
                              })}
                            </div>
                          )}
                        </div>
                      );
                    })()}
                  </div>

                  <div class="mt-auto">
                    <a
                      href={`/staff-development-day/${workshop.slug}`}
                      class="inline-block w-full text-center bg-brand-blue-600 text-white px-4 py-2 rounded hover:bg-brand-blue-700 transition-colors text-sm font-medium"
                    >
                      查看詳情
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="pb-16">
      <div class="container mx-auto px-4">
        <div class="bg-gray-50 rounded-2xl p-8 max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">活動照片集</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="group relative overflow-hidden rounded-xl">
              <Image
                src={gallery1}
                alt="香港教育城專業發展日"
                class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-110"
                width={768}
                height={576}
              />
              <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-70 transition-all duration-300 flex items-center justify-center">
                <div class="text-white text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <h3 class="font-semibold mb-2">香港教育城專業發展日</h3>
                  <p class="text-sm">
                    闡述人工智能對教育界的影響，向老師介紹無人駕駛系統及如何推動學生學習人工智能
                  </p>
                </div>
              </div>
            </div>

            <div class="group relative overflow-hidden rounded-xl">
              <Image
                src={gallery2}
                alt="浸大CLAP-TECH"
                class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-110"
                width={768}
                height={576}
              />
              <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-70 transition-all duration-300 flex items-center justify-center">
                <div class="text-white text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <h3 class="font-semibold mb-2">浸大CLAP-TECH</h3>
                  <p class="text-sm">
                    以實作形式指導老師學習編寫 python 程式，運用 python 及 Tensorflow
                    進行路牌辨識及將所學帶回學校與學生分享
                  </p>
                </div>
              </div>
            </div>

            <div class="group relative overflow-hidden rounded-xl">
              <Image
                src={gallery3}
                alt="教育局-教師專場1"
                class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-110"
                width={768}
                height={512}
              />
              <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-70 transition-all duration-300 flex items-center justify-center">
                <div class="text-white text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <h3 class="font-semibold mb-2">教育局-教師專場1</h3>
                  <p class="text-sm">在中學運用人工智能編程控制無人機於 STEM 教育相關的學習活動</p>
                </div>
              </div>
            </div>

            <div class="group relative overflow-hidden rounded-xl">
              <Image
                src={gallery4}
                alt="教育局-教師專場2"
                class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-110"
                width={768}
                height={512}
              />
              <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-70 transition-all duration-300 flex items-center justify-center">
                <div class="text-white text-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <h3 class="font-semibold mb-2">教育局-教師專場2</h3>
                  <p class="text-sm">在中學運用人工智能編程控制無人機於 STEM 教育相關的學習活動</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <RelatedNews
    courseTags={['教師培訓', 'AI教育', 'STEM', 'ChatGPT', '人工智能', 'Raspberry Pi', 'Donkey Car', '教師發展', '工作坊']}
    courseTitle="教師發展日工作坊"
    maxResults={6}
    context="course"
  />

  <section class="bg-brand-blue-600 text-white py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">準備好提升您的教學技能了嗎？</h2>
      <p class="text-xl text-brand-blue-100 mb-8 max-w-3xl mx-auto">
        加入我們的教師發展計劃，掌握最新的AI和STEM教學技術，為您的學生帶來更豐富的學習體驗。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <CTAButton href="/contact" text="聯絡我們" variant="white" size="lg" />
        <CTAButton
          href="/school-courses"
          text="查看課程"
          variant="outline"
          size="lg"
          class="border-2 border-white text-white hover:bg-white hover:text-brand-blue-600"
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1200px;
  }

  html {
    scroll-behavior: smooth;
  }

  .group:hover .group-hover\:scale-110 {
    transform: scale(1.1);
  }

  @media (max-width: 768px) {
    .text-6xl {
      font-size: 2.5rem;
    }
    .text-5xl {
      font-size: 2rem;
    }
  }
</style>
