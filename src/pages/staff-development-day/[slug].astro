---
// Dynamic route: English slug -> workshop .astro page (same pattern as stemday/[slug].astro).
// Duplicate slug↔filename literals: Astro's isolated `getStaticPaths` bundle cannot see sibling
// `const` nor reliably import derived maps from courseMappings.

import GeminiEducator from './Gemini Educator 特訓班.astro';
import ChatgptEducation from './ChatGPT在教育行業的運用講座.astro';
import AiGenerationLecture from './AI人工智能生成講座.astro';
import RaspberryPiPython from './Raspberry Pi與Python的運用講座.astro';
import DonkeyCarLecture from './Donkey Car無人車發展和應用講座.astro';

const componentMap = {
  'Gemini Educator 特訓班.astro': GeminiEducator,
  'ChatGPT在教育行業的運用講座.astro': ChatgptEducation,
  'AI人工智能生成講座.astro': AiGenerationLecture,
  'Raspberry Pi與Python的運用講座.astro': RaspberryPiPython,
  'Donkey Car無人車發展和應用講座.astro': DonkeyCarLecture,
};

export async function getStaticPaths() {
  const slugToFilenameMap = {
    'gemini-educator': 'Gemini Educator 特訓班.astro',
    'chatgpt-education': 'ChatGPT在教育行業的運用講座.astro',
    'ai-generation-lecture': 'AI人工智能生成講座.astro',
    'raspberry-pi-python': 'Raspberry Pi與Python的運用講座.astro',
    'donkey-car-lecture': 'Donkey Car無人車發展和應用講座.astro',
  };
  return Object.keys(slugToFilenameMap).map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error('Slug is required');
}

const slugToFilenameMap: Record<string, string> = {
  'gemini-educator': 'Gemini Educator 特訓班.astro',
  'chatgpt-education': 'ChatGPT在教育行業的運用講座.astro',
  'ai-generation-lecture': 'AI人工智能生成講座.astro',
  'raspberry-pi-python': 'Raspberry Pi與Python的運用講座.astro',
  'donkey-car-lecture': 'Donkey Car無人車發展和應用講座.astro',
};

const filename = slugToFilenameMap[slug];

if (!filename) {
  throw new Error(`Unknown staff development workshop slug: ${slug}`);
}

const WorkshopComponent = filename in componentMap ? componentMap[filename as keyof typeof componentMap] : null;

if (!WorkshopComponent) {
  throw new Error(`Component not found for filename: ${filename}`);
}
---

<WorkshopComponent />
