---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import StaffWorkshopPageSections from '../../components/staff-development/StaffWorkshopPageSections.astro';
import RelatedNews from '../../components/course/RelatedNews.astro';
import RelatedCourses from '../../components/course/RelatedCourses.astro';
import ContactSection from '../../components/ContactSection.astro';
import donkeyCar from '../../assets/images/staff-development-day/mainpage/donkey-car.jpeg';

export const courseData = {
  title: 'Donkey Car無人車發展和應用講座',
  subtitle: '無人車趨勢、Python 控制與機械學習體驗',
  description:
    '該講座將帶老師深入探索Donkey Car的發展和應用，包括介紹無人車技術，從構建到程式編寫，以及在教學中的實際運用。',
  detailedDescription:
    '講座帶領老師探索 Donkey Car 的發展與課堂應用：由 AI／無人駕駛趨勢與 Donkey Car 生態談起，講解硬件架構與 Python 控制基礎，並透過機械學習模型訓練與試駕體驗，協助教師設計富挑戰性的 STEM／創科活動。',
  tags: ['教師發展日', 'Donkey Car', '無人車', 'Python', 'STEM', '教師培訓', 'machine learning'],
  heroImage: donkeyCar,
  imageCaption:
    '與賽馬會多元出路計劃「鼓掌 – 創新教育歷程」合作向老師們分享Donkey Car的發展及實際操作',
  publishDate: '2024-04-10',
};

const workshopFeatures = [
  {
    icon: 'fas fa-route',
    title: '趨勢與發展',
    description: '瞭解人工智能與自動駕駛相關趨勢，以及 Donkey Car 在教育的定位。',
  },
  {
    icon: 'fas fa-car-side',
    title: '技術架構',
    description: '認識 Donkey Car 無人車的基本硬件、感測器與程式控制概念。',
  },
  {
    icon: 'fas fa-keyboard',
    title: 'Python 控制',
    description: '示範如何透過 Python 下達指令與調校車載系統行為。',
  },
  {
    icon: 'fas fa-project-diagram',
    title: '機械學習體驗',
    description: '簡介模型訓練流程，並安排試駕／模擬體驗自動駕駛決策。',
  },
];

const curriculum = [
  {
    title: '工作坊簡介',
    content: [
      '適合資訊科技、設計與科技或 STEM 统筹老師；可作為競賽隊伍或創科周的前置培訓。',
      '可按場地安排桌面示範或小型賽道演示。',
    ],
  },
  {
    title: '講座内容包括',
    content: [
      '瞭解人工智能的趨勢和 Donkey Car 無人車的發展',
      '了解 Donkey Car 無人車的技術和編程能力',
      '如何運用和透過 Python 編程繼而控制無人車',
      '透過 machine learning 訓練和體驗自動駕駛的模型',
    ],
  },
];

const faqItems = [
  {
    question: '講座是否需要大型場地？',
    answer: [
      '視乎校本選擇：可在較小範圍示範低速行駛，或使用模擬／錄影片段輔助。',
      '如需户外或禮堂賽道，請提早與同事協調電源與人流安排。',
    ],
  },
  {
    question: '如何邀請講座到校？',
    answer: ['請聯絡 +852 6554-1506 或 info@10botics.com，說明參與科組與期望日期。'],
  },
];
---

<Layout
  title={`${courseData.title} - 教師發展日 - 10教育`}
  description={courseData.description}
  ogImage={donkeyCar.src}
>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

  <main>
    <HeroSection
      title={courseData.title}
      subtitle={courseData.subtitle}
      description={courseData.detailedDescription}
      heroImage={courseData.heroImage}
      heroImageCaption={courseData.imageCaption}
      tags={courseData.tags}
      parentSectionHref="/staff-development-day/"
      parentSectionLabel="教師發展日"
    />

    <StaffWorkshopPageSections
      features={workshopFeatures}
      curriculum={curriculum}
      faqs={faqItems}
      contentHours="約 2–3 小時"
      curriculumSectionTitle="課程內容"
    />

    <RelatedCourses courseTags={courseData.tags} courseTitle={courseData.title} context="course" />

    <RelatedNews courseTags={courseData.tags} courseTitle={courseData.title} maxResults={6} context="course" />

    <ContactSection
      subtitle={`想了解更多關於「${courseData.title}」的資訊？歡迎聯絡我們，我們會為您提供詳細安排與報名資訊。`}
    />
  </main>
</Layout>
