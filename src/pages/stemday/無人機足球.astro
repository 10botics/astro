---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import QnASection from '../../components/course/QnASection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import ContactSection from '../../components/ContactSection.astro';

import heroImage from '../../assets/images/stemday/drone-football/hero-image.png';

const activityData: {
  title: string;
  subtitle: string;
  tags: string[];
  description: string;
  heroImageAsset: any;
} = {
  title: "無人機足球",
  subtitle: "無人機足球活動會讓同學們體驗嘗試以手控形式操控無人機，無人機會在網中飛行，導師會指導他們如何有效地控制無人機和穿過龍門。",
  tags: ["小一至中六", "每次約3分鐘", "每次最多2-3人"],
  description: "無人機足球讓同學以手控方式操控無人機在網中飛行並穿越龍門，體驗無人機操控技術，激發對科技的興趣。",
  heroImageAsset: heroImage
};

const activityFeatures = [
  {
    icon: "fas fa-gamepad",
    title: "親手操控無人機",
    description: "同學可親身嘗試以手控方式操控無人機，體驗真實的無人機飛行感受。"
  },
  {
    icon: "fas fa-futbol",
    title: "足球競技體驗",
    description: "無人機在封閉網場中飛行，嘗試穿越龍門，結合競技樂趣與科技體驗。"
  },
  {
    icon: "fas fa-shield-alt",
    title: "安全網場環境",
    description: "活動在專業無人機網場內進行，確保同學安全地體驗無人機操控樂趣。"
  },
  {
    icon: "fas fa-lightbulb",
    title: "激發科技興趣",
    description: "透過互動體驗，引發同學對無人機技術及航空科技的好奇心與探索精神。"
  }
];

const activitySchedule = [
  {
    title: "活動簡介",
    content: [
      "導師介紹無人機足球活動規則及無人機操控基本知識",
      "講解手控器使用方法及飛行安全注意事項"
    ]
  },
  {
    title: "無人機足球體驗",
    content: [
      "每次可同時供2-3人進行活動",
      "每次每人可玩2-3分鐘",
      "同學使用手控器操控無人機在網中飛行",
      "嘗試引導無人機穿過龍門，體驗競技樂趣",
      "導師全程在旁指導，協助同學掌握飛行技巧"
    ]
  }
];

const activityInfo = [
  { label: "可容納人數", value: "每次同時可供2-3人進行活動" },
  { label: "時長", value: "每次每人可玩2-3分鐘" },
  { label: "我們將會提供", value: "無人機足球 / 無人機網 / 搖控器 / 導師" },
  { label: "學校需提供/自備", value: "/" },
  { label: "備註", value: "1. 附近需要電源" },
];

const faqData = [
  {
    question: "這項活動適合哪些年級參與？",
    answer: "活動適合小一至中六同學參與，無需任何無人機操控經驗，導師會即場提供指導。"
  },
  {
    question: "每次活動可容納多少同學？",
    answer: "每次可同時供2-3人進行活動，每位同學每次約2至3分鐘，適合以攤位輪流形式進行。"
  },
  {
    question: "活動是否安全？",
    answer: "活動在專業無人機網場內進行，無人機全程在封閉網場中飛行，加上導師全程在場指導，確保同學安全體驗活動。"
  },
  {
    question: "學校需要準備什麼？",
    answer: "學校只需確保活動區域附近有電源即可。無人機足球場地、無人機網、搖控器及導師均由我們提供。"
  }
];

const { title, subtitle, tags, description, heroImageAsset: heroImg } = activityData;
---

<Layout title={title} description={description}>
  <main>
    <HeroSection
      title={title}
      subtitle={subtitle}
      tags={tags}
      description={description}
      heroImage={heroImg}
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">活動特色</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {activityFeatures.map((feature) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class={`${feature.icon} text-white text-2xl`}></i>
              </div>
              <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
              <p class="text-gray-600">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SingleCourseContent
      items={activitySchedule}
      hours="每人每次2-3分鐘"
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">活動資訊</h2>
          <div class="overflow-hidden rounded-lg shadow-lg border border-gray-200">
            <table class="w-full">
              <tbody>
                {activityInfo.map((item, i) => (
                  <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                    <td class="px-6 py-4 font-semibold text-gray-900 border-r border-gray-200 w-1/3 text-center">{item.label}</td>
                    <td class="px-6 py-4 text-gray-700 text-center whitespace-pre-line">{item.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <QnASection faqs={faqData} />

    <ContactSection subtitle="歡迎聯絡我們，我們會為您提供詳細的活動安排和報名資訊。" />
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.accordion-header').forEach(button => {
        button.addEventListener('click', () => {
          const item = button.parentElement;
          if (!item) return;
          const isActive = item.classList.contains('active');
          document.querySelectorAll('.accordion-item').forEach(accordionItem => {
            accordionItem.classList.remove('active');
          });
          if (!isActive) {
            item.classList.add('active');
          }
        });
      });
    });
  </script>

  <style>
    .accordion-content {
      display: none;
    }
    .accordion-item.active .accordion-content {
      display: block;
    }
    .accordion-item.active .accordion-header i {
      transform: rotate(45deg);
    }
  </style>
</Layout>
