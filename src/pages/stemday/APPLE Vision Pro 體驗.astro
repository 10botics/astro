---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import QnASection from '../../components/course/QnASection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import GalleryCarousel from '../../components/course/GalleryCarousel.astro';
import ContactSection from '../../components/ContactSection.astro';
import RelatedCourses from '../../components/course/RelatedCourses.astro';
import RelatedNews from '../../components/course/RelatedNews.astro';

import heroImage from '../../assets/images/stemday/apple-vision-pro/hero-image.png';
import galleryImg1 from '../../assets/images/stemday/apple-vision-pro/gallery-1.png';

const activityData: {
  title: string;
  subtitle: string;
  tags: string[];
  description: string;
  heroImageAsset: any;
} = {
  title: "APPLE Vision Pro 體驗",
  subtitle: "沉浸式體驗虛擬現實，探索最新科技！",
  tags: ["虛擬實境", "沉浸式體驗", "小一至中五"],
  description: "學生將可以沉浸式體驗虛擬現實，導師會指導學生如何操作 Apple Vision Pro 並進行試玩，了解更多新科技。透過親身體驗全球最先進的混合實境頭戴式裝置，學生能夠感受虛擬與現實融合的奇妙世界，認識 XR 擴展實境技術在教育、娛樂及各行各業的廣泛應用前景。",
  heroImageAsset: heroImage
};

const activityFeatures = [
  {
    icon: "fas fa-vr-cardboard",
    title: "沉浸式虛擬現實",
    description: "透過 Apple Vision Pro 體驗業界頂尖的混合實境技術，學生可在虛擬世界中探索、互動，感受科技帶來的無限可能。"
  },
  {
    icon: "fas fa-hand-pointer",
    title: "直覺式操作體驗",
    description: "Apple Vision Pro 採用眼動、手勢及語音控制，無需手制，學生可直接用眼睛和手指進行操作，體驗全新的人機互動方式。"
  },
  {
    icon: "fas fa-chalkboard-teacher",
    title: "導師全程指導",
    description: "專業導師在旁全程協助，耐心指導每位學生正確佩戴及操作 Apple Vision Pro，確保每人都能享受安全愉快的體驗。"
  },
  {
    icon: "fas fa-lightbulb",
    title: "認識前沿科技",
    description: "透過親身體驗了解 XR 擴展實境的原理及應用，啟發學生對科技創新的興趣，拓闊視野，認識未來科技發展趨勢。"
  }
];

const activitySchedule = [
  {
    title: "簡介與準備 [約1分鐘]",
    content: [
      "導師簡單介紹 Apple Vision Pro 的功能及操作方式",
      "解釋佩戴方式及基本手勢控制（眼動追蹤、手指點擊、手掌展開）",
      "協助學生正確佩戴頭戴裝置，調整至舒適位置"
    ]
  },
  {
    title: "沉浸式體驗 [約3-5分鐘]",
    content: [
      "學生在導師引導下進入虛擬實境體驗內容",
      "透過眼動及手勢操控虛擬介面，探索互動式體驗",
      "導師從旁協助，確保體驗順暢及安全"
    ]
  },
  {
    title: "分享與啟發",
    content: [
      "導師分享 XR 技術在醫療、教育、設計及娛樂等行業的實際應用",
      "鼓勵學生思考未來科技發展，啟發對 STEM 領域的好奇心"
    ]
  }
];

const activityInfo = [
  { label: "可容納人數", value: "每次同時可供1人進行活動" },
  { label: "時長", value: "每次每人可玩3-5分鐘" },
  { label: "我們將會提供", value: "APPLE Vision Pro 套裝、體驗內容" },
  { label: "學校需提供/自備", value: "電視/ 屏幕、Apple TV/ Air Play、電源位、桌椅" },
  { label: "備註", value: "1. 附近需要電源" },
];

const faqData = [
  {
    question: "這項活動適合什麼年級的同學參與？",
    answer: "活動適合小一至中五的學生參與。考慮到頭戴裝置的重量及操作難度，建議由低年級至高年級均可參與，導師會根據學生年齡調整體驗內容及難度。"
  },
  {
    question: "每次可以有多少人同時體驗？",
    answer: "每次只可供1人佩戴 Apple Vision Pro 進行體驗，每次體驗時間約3-5分鐘。如需安排更多學生，可視乎活動時間靈活調配輪流體驗。"
  },
  {
    question: "佩戴 Apple Vision Pro 安全嗎？會令眼睛不適嗎？",
    answer: "Apple Vision Pro 設計符合人體工學，短時間使用對眼睛影響輕微。導師會控制每人的體驗時間在5分鐘以內，並提醒學生如感不適應立即告知。患有視力問題或暈動症的學生，建議先諮詢家長意見。"
  },
  {
    question: "學校需要準備什麼？",
    answer: "學校需要提供電視或屏幕（用作旁觀展示）、支援 Apple TV 或 AirPlay 的設備、附近的電源位，以及桌椅供放置裝置。我們將提供所有 Apple Vision Pro 套裝及體驗內容。"
  },
  {
    question: "攤位需要多大的空間？",
    answer: "攤位所需空間不大，一張桌子加周邊空間即可。建議在較安靜、光線適中的區域設置，以確保體驗質素。附近需有電源插座。"
  }
];

const { title, subtitle, tags, description, heroImageAsset: heroImg } = activityData;
---

<Layout title={title} description={description}>
  <main>
    <HeroSection 
      title={title}
      subtitle={subtitle}
      tags={tags}
      description={description}
      heroImage={heroImg}
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">活動特色</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {activityFeatures.map((feature) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-brand-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class={`${feature.icon} text-white text-2xl`}></i>
              </div>
              <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
              <p class="text-gray-600">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SingleCourseContent 
      items={activitySchedule}
      hours="每人每次3-5分鐘"
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <GalleryCarousel title="活動花絮" images={[galleryImg1]} intervalMs={4000} />
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">活動資訊</h2>
          <div class="overflow-hidden rounded-lg shadow-lg border border-gray-200">
            <table class="w-full">
              <tbody>
                {activityInfo.map((item, i) => (
                  <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                    <td class="px-6 py-4 font-semibold text-gray-900 border-r border-gray-200 w-1/3 text-center">{item.label}</td>
                    <td class="px-6 py-4 text-gray-700 text-center">{item.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <QnASection faqs={faqData} />

    <RelatedCourses courseTags={tags} courseTitle={title} context="course" />
    <RelatedNews courseTags={tags} courseTitle={title} context="course" />

    <ContactSection subtitle="歡迎聯絡我們，我們會為您提供詳細的活動安排和報名資訊。" />
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.accordion-header').forEach(button => {
        button.addEventListener('click', () => {
          const item = button.parentElement;
          if (!item) return;
          const isActive = item.classList.contains('active');
          document.querySelectorAll('.accordion-item').forEach(accordionItem => {
            accordionItem.classList.remove('active');
          });
          if (!isActive) {
            item.classList.add('active');
          }
        });
      });
    });
  </script>

  <style>
    .accordion-content {
      display: none;
    }
    .accordion-item.active .accordion-content {
      display: block;
    }
    .accordion-item.active .accordion-header i {
      transform: rotate(45deg);
    }
  </style>
</Layout>
