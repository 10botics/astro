---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import QnASection from '../../components/course/QnASection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import { Image } from 'astro:assets';
import ContactSection from '../../components/ContactSection.astro';

import heroImage from '../../assets/images/stemday/mainpage/marty-robot.png';

const activityData: {
  title: string;
  subtitle: string;
  tags: string[];
  description: string;
  heroImageAsset: any;
} = {
  title: "Marty編程機械人",
  subtitle: "在Marty編程機械人活動體驗中，同學們能夠掌握更多Marty機械人的基本概念和操作原理，並且我們會教導同學們嘗試控制Marty機器人和編程Marty機械人的動作和行為程序。",
  tags: ["編程", "機械人", "初小", "高小"],
  description: "Marty編程機械人活動體驗讓同學掌握Marty機械人的基本概念和操作原理，學習控制和編程Marty機械人的動作和行為程序。",
  heroImageAsset: heroImage
};

const activityFeatures = [
  {
    icon: "fas fa-robot",
    title: "認識編程機械人",
    description: "讓同學認識Marty機械人的基本概念和操作原理，了解機械人編程的基礎知識。"
  },
  {
    icon: "fas fa-code",
    title: "動手編程體驗",
    description: "同學可以親手使用平板電腦上的編程軟件，控制Marty機械人執行不同的動作和行為。"
  },
  {
    icon: "fas fa-chalkboard-teacher",
    title: "導師全程指導",
    description: "活動期間我們的導師會全程提供協助，教導同學們掌握編程技巧並順利完成操作。"
  },
  {
    icon: "fas fa-child",
    title: "適合小學生參與",
    description: "活動專為小一至小六學生設計，以簡單易懂的方式讓同學體驗編程樂趣。"
  }
];

const activitySchedule = [
  {
    title: "活動簡介",
    content: [
      "導師介紹Marty編程機械人的基本概念和操作原理",
      "說明活動流程及編程軟件操作方法"
    ]
  },
  {
    title: "Marty編程體驗",
    content: [
      "每部機械人每次可供1人進行活動",
      "每次每人可玩2分鐘",
      "使用平板電腦上的編程軟件控制Marty機械人",
      "導師從旁指導同學編程Marty的動作和行為程序"
    ]
  }
];

const activityInfo = [
  { label: "容納人數", value: "每部機械人每次可供1人進行活動" },
  { label: "時長", value: "每次每人可玩2分鐘" },
  { label: "我們將會提供", value: "Marty編程機械人 / 平板電腦 / 編程軟件" },
  { label: "學校需提供/自備", value: "桌子" },
];

const faqData = [
  {
    question: "這項活動適合什麼年級的同學參與？",
    answer: "這項活動適合小一至小六學生參與。"
  },
  {
    question: "每次活動可以容納多少人？",
    answer: "每部機械人每次可供1人進行活動，每人每次可玩2分鐘。攤位可同時提供多部機械人供同學輪流體驗。"
  },
  {
    question: "學校需要準備什麼？",
    answer: "學校只需提供桌子。我們將提供Marty編程機械人、平板電腦及編程軟件。\n\n建議先致電+852 6554-1506 或電郵至 info@10botics.com 向同事溝通學校期望的活動內容及安排。"
  }
];

const { title, subtitle, tags, description, heroImageAsset: heroImg } = activityData;
---

<Layout title={title} description={description}>
  <main>
    <HeroSection 
      title={title}
      subtitle={subtitle}
      tags={tags}
      description={description}
      heroImage={heroImg}
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">活動特色</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {activityFeatures.map((feature) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class={`${feature.icon} text-white text-2xl`}></i>
              </div>
              <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
              <p class="text-gray-600">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SingleCourseContent 
      items={activitySchedule}
      hours="每人每次2分鐘"
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">活動資訊</h2>
          <div class="overflow-hidden rounded-lg shadow-lg border border-gray-200">
            <table class="w-full">
              <tbody>
                {activityInfo.map((item, i) => (
                  <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                    <td class="px-6 py-4 font-semibold text-gray-900 border-r border-gray-200 w-1/3 text-center">{item.label}</td>
                    <td class="px-6 py-4 text-gray-700 text-center">{item.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <QnASection faqs={faqData} />

    <ContactSection subtitle="歡迎聯絡我們，我們會為您提供詳細的活動安排和報名資訊。" />
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.accordion-header').forEach(button => {
        button.addEventListener('click', () => {
          const item = button.parentElement;
          if (!item) return;
          const isActive = item.classList.contains('active');
          document.querySelectorAll('.accordion-item').forEach(accordionItem => {
            accordionItem.classList.remove('active');
          });
          if (!isActive) {
            item.classList.add('active');
          }
        });
      });
    });
  </script>

  <style>
    .accordion-content {
      display: none;
    }
    .accordion-item.active .accordion-content {
      display: block;
    }
    .accordion-item.active .accordion-header i {
      transform: rotate(45deg);
    }
  </style>
</Layout>
