---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import QnASection from '../../components/course/QnASection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import ContactSection from '../../components/ContactSection.astro';

import heroImage from '../../assets/images/Stemday/hand-clap-keirin-race/hero-image.png';

const activityData: {
  title: string;
  subtitle: string;
  tags: string[];
  description: string;
  heroImageAsset: any;
} = {
  title: "手拍凱林賽",
  subtitle: "比拼手速，拍打感應燈板驅動賽車，在緊張競技中認識微處理器原理！",
  tags: ["小一至中六", "每次約1分鐘", "每次最多4人"],
  description: "手拍凱林賽將競技運動與微處理器科技完美融合！最多4位同學同時上陣，以最快手速連續拍打各自的感應燈板，驅動賽道上的賽車全速衝向終點，先到達者勝出。感應燈板內置微處理器，能即時接收拍打觸碰訊號並轉換為計分指令，讓同學在激烈競技中自然認識訊號輸入與輸出的概念。活動設計參考凱林賽的競技精神，考驗同學的反應速度、節奏感與持久力，多人競賽氣氛令在場同學相互加油。導師亦會分享微處理器在智能手機、家用電器及工業控制系統等日常科技產品的廣泛應用，讓同學了解科技與生活的緊密連繫。",
  heroImageAsset: heroImage
};

const activityFeatures = [
  {
    icon: "fas fa-microchip",
    title: "認識微處理器原理",
    description: "感應燈板內置微處理器，能即時接收同學拍打時的觸碰訊號並作出反應，驅動賽道上的計分系統。透過親身體驗，同學輕鬆了解微處理器的感應輸入與輸出原理，建立對電子元件的基本認識。"
  },
  {
    icon: "fas fa-hand-paper",
    title: "極速反應手速挑戰",
    description: "同學需以最快速度持續拍打感應燈板，手速越快，賽車前進越快！整個過程考驗同學的反應速度、節奏感與持久力，在緊張刺激的競賽氣氛中激發鬥志，場面熱鬧非凡。"
  },
  {
    icon: "fas fa-trophy",
    title: "模擬凱林賽競賽體驗",
    description: "活動設計參考香港著名賽馬項目——凱林賽的競技精神，以賽道積分形式分出勝負。同學化身賽車手，體驗從起跑到衝線的緊張節奏，培養競爭意識的同時亦學習運動精神。"
  },
  {
    icon: "fas fa-users",
    title: "多人同場競技互動",
    description: "每次最多4人同時上陣，熱鬧的多人競賽氣氛讓同學相互加油打氣，觀眾和參賽者都能感受到激烈的競技樂趣，非常適合班際比賽或全校STEM Day的攤位體驗活動。"
  }
];

const activitySchedule = [
  {
    title: "活動簡介與科技知識講解 [約30秒]",
    content: [
      "導師介紹手拍凱林賽的玩法規則及感應燈板的工作原理",
      "講解微處理器如何即時接收拍打訊號並轉換為賽車前進的指令",
      "示範正確的拍板姿勢，讓同學了解如何最有效地傳遞訊號"
    ]
  },
  {
    title: "熱身練習 [約15秒]",
    content: [
      "同學各自試拍感應燈板，熟悉板面的感應靈敏度",
      "感受微處理器對拍打動作的即時回應，觀察賽車移動速度的變化"
    ]
  },
  {
    title: "手拍凱林賽正式競賽 [約45秒]",
    content: [
      "每次可同時供最多4人並排參與競賽",
      "發令後，所有參賽者以最快手速拍打各自的感應燈板",
      "賽車在賽道上實時推進，率先到達終點者勝出",
      "導師擔任裁判，宣布成績並表揚優勝者"
    ]
  },
  {
    title: "科技討論與分享",
    content: [
      "導師與同學討論微處理器在日常生活中的廣泛應用，如智能手機、電腦、家電等",
      "分享觸感感應技術在其他科技產品中的運用，如智能門鈴、電子門鎖及工業控制系統",
      "鼓勵同學思考：如果你是工程師，你會如何設計一個更快更準的感應系統？"
    ]
  }
];

const activityInfo = [
  { label: "容納人數", value: "每次可同時4人進行活動" },
  { label: "時長", value: "1分鐘" },
  { label: "我們將會提供", value: "手拍凱林賽燈板一套" },
  { label: "學校需提供/自備", value: "桌子／\n900x1200mm可移動壁報板或白板" },
  { label: "備註", value: "1. 附近需要電源\n2. 另設常規課程" },
];

const faqData = [
  {
    question: "這項活動適合哪些年級參與？",
    answer: "活動適合小一至中六同學參與，操作方式簡單直觀，不需要任何科技知識或技術背景，任何年齡的同學都能立即投入競賽樂趣。活動亦非常適合作為全校STEM Day的熱鬧攤位體驗。"
  },
  {
    question: "每次活動可容納多少同學？",
    answer: "每次最多可供4人同時並排競賽，每次競賽約1分鐘，輪替速度快，非常適合以攤位輪流形式進行，讓大量同學在短時間內都有機會參與體驗。"
  },
  {
    question: "學校需要準備什麼設備和場地？",
    answer: "學校需提供：\n• 一張桌子用於放置燈板系統\n• 900x1200mm可移動壁報板或白板（用於展示賽道）\n• 活動區域附近的電源\n\n我們會提供完整的手拍凱林賽燈板系統一套，並由我們的工作人員負責安裝設置。"
  },
  {
    question: "活動有常規課程選項嗎？",
    answer: "是的！除STEM Day攤位體驗外，我們另設手拍凱林賽常規課程，可讓同學深入學習微處理器和感應技術的原理，甚至嘗試自行編程控制感應系統。歡迎聯絡我們了解課程詳情及報名安排。"
  },
  {
    question: "同學在活動中能學到什麼科技知識？",
    answer: "同學將了解微處理器的基本工作原理——如何接收外部訊號（輸入）並作出相應的指令輸出。活動亦讓同學體驗觸感感應技術在實際設備中的應用。導師會在活動中分享微處理器在日常科技產品中的廣泛應用，如智能手機、家用電器、工業控制系統等，讓同學理解科技與生活的緊密連繫。"
  }
];

const { title, subtitle, tags, description, heroImageAsset: heroImg } = activityData;
---

<Layout title={title} description={description}>
  <main>
    <HeroSection
      title={title}
      subtitle={subtitle}
      tags={tags}
      description={description}
      heroImage={heroImg}
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">活動特色</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {activityFeatures.map((feature) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class={`${feature.icon} text-white text-2xl`}></i>
              </div>
              <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
              <p class="text-gray-600">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SingleCourseContent
      items={activitySchedule}
      hours="每次約1分鐘"
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">活動資訊</h2>
          <div class="overflow-hidden rounded-lg shadow-lg border border-gray-200">
            <table class="w-full">
              <tbody>
                {activityInfo.map((item, i) => (
                  <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                    <td class="px-6 py-4 font-semibold text-gray-900 border-r border-gray-200 w-1/3 text-center">{item.label}</td>
                    <td class="px-6 py-4 text-gray-700 text-center whitespace-pre-line">{item.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <QnASection faqs={faqData} />

    <ContactSection subtitle="歡迎聯絡我們，我們會為您提供詳細的活動安排和報名資訊。" />
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.accordion-header').forEach(button => {
        button.addEventListener('click', () => {
          const item = button.parentElement;
          if (!item) return;
          const isActive = item.classList.contains('active');
          document.querySelectorAll('.accordion-item').forEach(accordionItem => {
            accordionItem.classList.remove('active');
          });
          if (!isActive) {
            item.classList.add('active');
          }
        });
      });
    });
  </script>

  <style>
    .accordion-content {
      display: none;
    }
    .accordion-item.active .accordion-content {
      display: block;
    }
    .accordion-item.active .accordion-header i {
      transform: rotate(45deg);
    }
  </style>
</Layout>
