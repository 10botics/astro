---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import QnASection from '../../components/course/QnASection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import { Image } from 'astro:assets';
import ContactSection from '../../components/ContactSection.astro';

import heroImage from '../../assets/images/stemday/mainpage/ar-game-experience.png';

const activityData: {
  title: string;
  subtitle: string;
  tags: string[];
  description: string;
  heroImageAsset: any;
} = {
  title: "AR遊戲體驗",
  subtitle: "AR遊戲體驗活動可以讓同學們了解AR遊戲如何結合虛擬與現實，並且在活動當中，我們導師也會提供協助，讓同學們能夠明白當中原理，以及可以順利進行遊戲操作。",
  tags: ["AR 擴增實境", "遊戲體驗", "初小", "高小", "初中", "高中"],
  description: "AR遊戲體驗活動可以讓同學們了解AR遊戲如何結合虛擬與現實，並且在活動當中，我們導師也會提供協助，讓同學們能夠明白當中原理，以及可以順利進行遊戲操作。",
  heroImageAsset: heroImage
};

const activityFeatures = [
  {
    icon: "fas fa-vr-cardboard",
    title: "虛實結合體驗",
    description: "透過AR擴增實境技術，讓同學在現實環境中體驗虛擬遊戲元素，認識AR技術的應用原理。"
  },
  {
    icon: "fas fa-gamepad",
    title: "互動遊戲學習",
    description: "以遊戲形式進行學習，讓同學在輕鬆有趣的氛圍中認識AR技術，提升學習動機。"
  },
  {
    icon: "fas fa-chalkboard-teacher",
    title: "導師全程協助",
    description: "活動期間我們的導師會全程提供協助，確保同學能夠明白當中原理並順利進行遊戲操作。"
  },
  {
    icon: "fas fa-users",
    title: "適合各年級學生",
    description: "活動適合小一至中六學生，內容可按不同年級作出調整，讓各級學生都能有所得著。"
  }
];

const activitySchedule = [
  {
    title: "活動簡介",
    content: [
      "導師介紹AR擴增實境技術的基本概念",
      "說明活動流程及遊戲操作方法"
    ]
  },
  {
    title: "AR遊戲體驗",
    content: [
      "每次可供6人同時進行活動",
      "每人每次可玩1-2分鐘",
      "導師從旁協助同學操作"
    ]
  }
];

const activityInfo = [
  { label: "容納人數", value: "每次可供6人進行活動" },
  { label: "時長", value: "每次每人可玩1-2分鐘" },
  { label: "我們將會提供", value: "AR背景海報 / AR遊戲 / 遊戲介紹易拉架" },
  { label: "學校需提供/自備", value: "可移動壁報或白板 / 平板電腦" },
];

const faqData = [
  {
    question: "這項活動適合什麼年級的同學參與？",
    answer: "這項活動適合小一至中六學生參與。"
  },
  {
    question: "每次活動可以容納多少人？",
    answer: "每次可供6人同時進行活動，每人每次可玩1-2分鐘。"
  },
  {
    question: "學校需要準備什麼？",
    answer: "學校需提供可移動壁報或白板以及平板電腦。我們將提供AR背景海報、AR遊戲及遊戲介紹易拉架。\n\n建議先致電+852 6554-1506 或電郵至 info@10botics.com 向同事溝通學校期望的活動內容及安排。"
  }
];

const { title, subtitle, tags, description, heroImageAsset: heroImg } = activityData;
---

<Layout title={title} description={description}>
  <main>
    <!-- Hero Section -->
    <HeroSection 
      title={title}
      subtitle={subtitle}
      tags={tags}
      description={description}
      heroImage={heroImg}
    />

    <!-- Activity Features -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">活動特色</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {activityFeatures.map((feature) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class={`${feature.icon} text-white text-2xl`}></i>
              </div>
              <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
              <p class="text-gray-600">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Activity Content -->
    <SingleCourseContent 
      items={activitySchedule}
      hours="每人每次1-2分鐘"
    />

    <!-- Activity Info Table -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">活動資訊</h2>
          <div class="overflow-hidden rounded-lg shadow-lg border border-gray-200">
            <table class="w-full">
              <tbody>
                {activityInfo.map((item, i) => (
                  <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                    <td class="px-6 py-4 font-semibold text-gray-900 border-r border-gray-200 w-1/3 text-center">{item.label}</td>
                    <td class="px-6 py-4 text-gray-700 text-center">{item.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <QnASection faqs={faqData} />

    <!-- Contact Section -->
    <ContactSection subtitle="歡迎聯絡我們，我們會為您提供詳細的活動安排和報名資訊。" />
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.accordion-header').forEach(button => {
        button.addEventListener('click', () => {
          const item = button.parentElement;
          if (!item) return;
          const isActive = item.classList.contains('active');
          document.querySelectorAll('.accordion-item').forEach(accordionItem => {
            accordionItem.classList.remove('active');
          });
          if (!isActive) {
            item.classList.add('active');
          }
        });
      });
    });
  </script>

  <style>
    .accordion-content {
      display: none;
    }
    .accordion-item.active .accordion-content {
      display: block;
    }
    .accordion-item.active .accordion-header i {
      transform: rotate(45deg);
    }
  </style>
</Layout>
