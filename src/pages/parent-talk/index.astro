---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import QnASection from '../../components/course/QnASection.astro';
import ContactSection from '../../components/ContactSection.astro';
import RelatedCourses from '../../components/course/RelatedCourses.astro';
import GalleryCarousel from '../../components/course/GalleryCarousel.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { generateExcerpt } from '../../utils/excerpt';
import { TAG_MAPPING } from '../../utils/tagMapping';

import heroImage from '../../assets/images/parent-talk/ai-improve-study-efficiency/gallery-stage-openai-ai-development-education.png';
import galleryAuditoriumAiEducation from '../../assets/images/parent-talk/ai-improve-study-efficiency/gallery-auditorium-ai-education-slide.png';
import galleryClassroomParentTalk from '../../assets/images/parent-talk/ai-improve-study-efficiency/gallery-classroom-parent-talk.png';
import gallerySchoolUpdates from '../../assets/images/parent-talk/gallery-school-updates.png';
import galleryParentSchoolPartnership from '../../assets/images/parent-talk/gallery-parent-school-partnership.png';
import galleryParentTalkHallPresentation from '../../assets/images/parent-talk/gallery-parent-talk-hall-presentation.png';

/** Canonical URL: /parent-talk */
export const courseData = (() => {
  const staffAndSchoolCourseSummary =
    '給教師與校方：本講座對準家長教育與科技素養方向。工作坊呼應教育局家長教育方針，與「家長智Net」等官方網上資源方向互相扣連，把生成式人工智能、提示工程與輔助功課的在地脈絡落到實處，讓家校以同一套語言談學習與網上安全。系統化示範與討論有助家長建立事實核查、學術誠信與私隱界線等共識，減輕教師反覆解答 AI 疑惑的負擔。對決策同工而言，安排講座即向社群表明學校重視家校合作與數碼時代家長賦能，與以網絡與講座支援家長的政策方向一致，並主動縮窄課堂創新與家庭支援之間的鴻溝。';
  return {
    title: '利用人工智能提昇學習效能',
    subtitle: 'AI 世代的學習新模式 — 透過人工智能提升子女的學習效能（POE 實作工作坊）',
    tags: [
      '家長講座',
      'AI 人工智能',
      'Google Gemini',
      'ChatGPT',
    ].filter((tag) => Object.hasOwn(TAG_MAPPING, tag)),
    description: staffAndSchoolCourseSummary,
    detailedDescription: staffAndSchoolCourseSummary,
    heroImage,
  };
})();

const courseHighlights = [
  {
    icon: 'fas fa-comments',
    title: 'POE 一站式上手多款 AI',
    description:
      '理解香港地區使用限制與 VPN 議題；認識 POE 如何集合 ChatGPT、Gemini、Claude、Grok 等，以及學校／公司 Gmail 使用 Gemini 的特例。',
  },
  {
    icon: 'fas fa-clipboard-check',
    title: '貼近家課與測考的實作',
    description:
      '由拍照檢查答案、純文字／附圖生成測驗，到作文大綱與分段寫作、閱讀報告總結、成語造句與英文文法檢查，一步步可在家庭中重現。',
  },
  {
    icon: 'fas fa-shield-heart',
    title: 'AI 素養與安全界線',
    description:
      '討論幻覺與事實核查、深度偽造與法律、學術誠信的合理使用方式，以及不向 AI 洩露過度個人資料等私隱意識。',
  },
];

const courseCurriculum = {
  items: [
    {
      title: '如何使用 AI：POE 與對話基礎',
      duration: '約 1 單元',
      content: [
        '香港使用 ChatGPT／Gemini 的限制與為何以 POE 作為多模型入口（含多款模型概覽）',
        '下載登入、廣東話語音與基礎對話練習',
        '選用 Gemini-2.5-Flash、比較不同模型表現，並調整預設 Assistant',
      ],
    },
    {
      title: '點數與進階功能',
      duration: '約 1 單元',
      content: [
        'POE 點數規則與不同模型的大致消耗',
        '學習應用：檢查功課、生成測驗、作文輔助、閱讀報告、造句／慣用語與英文文法檢查',
        '分享與對話歷史；Stable Diffusion XL 圖片生成（字／圖生圖）及操作要點',
      ],
    },
    {
      title: 'Bot、訂閱與 AI 素養',
      duration: '約 1 單元',
      content: [
        '專屬 Bot（如測驗機械人）與製作／訂閱流程；iOS 與網頁版訂閱差異',
        '準確性與幻覺、深度偽造、學術誠信與個人私隱',
      ],
    },
  ],
};

const faqItems = [
  {
    question: '為什麼示範環節會選用 POE？',
    answer: [
      '同一介面可展示多款模型，適合向家長說明「不同 AI 回答有何分別」與實際可用的組合方式。',
      '講者會配合貴校情境，概述 ChatGPT／Gemini 等地區限制與替代做法，便於家長理解現實環境。',
    ],
  },
  {
    question: '學校安排講座時，一般要預留什麼？',
    answer: [
      '通常需要投影或大屏幕、音響及穩定無線網絡；若希望家長現場跟著操作，可再預留電源與座位。',
      '單次時長、拆節或系列講座均可按貴校家長日／講座檔期商議。',
    ],
  },
  {
    question: '如何洽談日期或調整講座重點？',
    answer: [
      '請透過頁底聯絡方式與我們說明對象、時段與希望加強的部分（例如偏重工具示範或 AI 素養討論）。',
      '同事會按校方需要建議合適的環節長度與流程。',
    ],
  },
];

const PARENT_TALK_TAG = '家長講座';
const allNews = await getCollection('news');
const parentTalkNews = allNews
  .filter((article) => article.data.tags?.includes(PARENT_TALK_TAG))
  .map((article) => ({
    ...article,
    data: {
      ...article.data,
      excerpt: article.data.excerpt || generateExcerpt(article.body, 150),
    },
  }))
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title={`${courseData.title} - 家長講座 - 10教育`}
  description={courseData.description}
  ogImage={heroImage.src}
>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

  <main>
    <HeroSection
      title={courseData.title}
      subtitle={courseData.subtitle}
      description={courseData.detailedDescription}
      heroImage={courseData.heroImage}
      heroImageMaxScale={0.8}
      tags={courseData.tags}
      rootSectionHref="/school-courses"
      rootSectionLabel="到校服務"
      parentSectionHref="/parent-talk"
      parentSectionLabel="家長講座"
      endBreadcrumbAtParentSection={true}
    />

    <section class="section-padding bg-white">
      <div class="container-standard">
        <GalleryCarousel
          title="講座實況"
          images={[
            {
              src: galleryAuditoriumAiEducation,
              alt: '學校禮堂內，家長坐在觀眾席聆聽講座，大螢幕投影「AI 教育」主題簡報與數位人像圖像，講者持麥克風於台前分享。',
            },
            {
              src: galleryClassroomParentTalk,
              alt: '課室或小型禮堂內舉行家長講座，家長坐於藍色座椅面向講台，女講者持麥於投影幕前講解。',
            },
            {
              src: gallerySchoolUpdates,
              alt: '學校禮堂內舉行家長講座，講者於台前分享，大螢幕顯示「School Updates」主題簡報，家長於觀眾席面向舞台聆聽。',
            },
            {
              src: galleryParentSchoolPartnership,
              alt: '課室內「家校合作」主題家長講座，講者於講台前主持，投影幕列出重點日程、義工機會與問答環節，家長安坐聆聽。',
            },
            {
              src: galleryParentTalkHallPresentation,
              alt: '學校活動場地舉行家長講座，家長坐於藍色座椅面向投影幕；牆身展示獎杯櫃，女講者持麥克風於台前講解圖文化簡報。',
            },
          ]}
          intervalMs={4500}
        />
      </div>
    </section>

    <section class="section-padding bg-gray-50">
      <div class="container-standard">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">講座亮點</h2>
          <p class="text-gray-600 max-w-3xl mx-auto">
            示範為主、家長向 — 由工具選擇、日常學習應用到 AI 素養與界線，一次掌握「敢用、會用、用得安全」。
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {courseHighlights.map((item) => (
            <div class="card-base card-hover p-6">
              <div class="flex items-start">
                <div class="text-3xl text-brand-cyan-600 mr-4">
                  <i class={item.icon}></i>
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 mb-3">{item.title}</h3>
                  <p class="text-gray-600">{item.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SingleCourseContent
      items={courseCurriculum.items}
      hours="按校情調整（常見為單次約 2–3 小時或拆節）"
      hoursText="時長"
      sectionTitle="講座大綱"
      showAdjustmentNote={true}
      adjustmentText="環節次序、深度與時長可按貴校家長講座時段調整；亦可配合跟進工作坊。"
    />

    <QnASection
      title="常見問題"
      subtitle="FAQ"
      description="為準備或安排家長工作坊的教師／同工常見問題"
      faqs={faqItems.map((item) => ({
        question: item.question,
        answer: item.answer.join('\n\n'),
      }))}
    />

    <RelatedCourses
      courseTags={courseData.tags}
      courseTitle={courseData.title}
      currentCourseSlug="parent-talk"
      context="course"
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">相關新聞與活動回顧</h2>
          <p class="text-lg text-gray-600">
            共 {parentTalkNews.length} 篇報導（標籤：{PARENT_TALK_TAG}）
          </p>
        </div>

        {parentTalkNews.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {parentTalkNews.map((article) => (
              <article class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow group hover:border-gray-300">
                {article.data.featuredImage && (
                  <div class="aspect-video overflow-hidden">
                    <Image
                      src={article.data.featuredImage as any}
                      alt={article.data.title}
                      width={600}
                      height={400}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}

                <div class="p-6">
                  <div class="flex items-center justify-between text-sm text-gray-500 mb-3">
                    <span class="bg-cyan-100 text-cyan-800 px-2 py-1 rounded-full text-xs font-medium">
                      {article.data.category}
                    </span>
                    <time datetime={article.data.publishDate.toISOString()}>
                      {formatDate(article.data.publishDate)}
                    </time>
                  </div>

                  <h3 class="text-lg font-semibold text-gray-900 mb-3 line-clamp-2 hover:text-cyan-600 transition-colors">
                    <a href={`/news/${article.slug}`} class="hover:underline">
                      {article.data.title}
                    </a>
                  </h3>

                  <p class="text-gray-600 text-sm mb-4 line-clamp-3">{article.data.excerpt}</p>

                  {article.data.tags && article.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      {article.data.tags.slice(0, 4).map((tag) => (
                        <span class="bg-cyan-100 text-cyan-800 px-2 py-1 rounded text-xs">{tag}</span>
                      ))}
                      {article.data.tags.length > 4 && (
                        <span class="text-xs text-cyan-500">+{article.data.tags.length - 4}</span>
                      )}
                    </div>
                  )}

                  <a
                    href={`/news/${article.slug}`}
                    class="inline-flex items-center text-cyan-600 hover:text-cyan-700 font-medium text-sm group-hover:underline"
                  >
                    閱讀更多
                    <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="text-center text-gray-600 py-8">目前尚無帶有「家長講座」標籤的新聞。</p>
        )}
      </div>
    </section>

    <ContactSection
      subtitle={`想了解更多關於「${courseData.title}」或為貴校安排家長講座？歡迎聯絡 info@10botics.com 或致電 6554-1506。`}
    />
  </main>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
