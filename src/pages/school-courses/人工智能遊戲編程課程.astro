---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import QnASection from '../../components/course/QnASection.astro';
import ContactSection from '../../components/ContactSection.astro';
import RelatedNews from '../../components/course/RelatedNews.astro';
import RelatedCourses from '../../components/course/RelatedCourses.astro';
import { Image } from 'astro:assets';

// Import student work images
import ticTacToe1 from '../../assets/images/school-courses/人工智能遊戲編程課程/student-work/student-work-1.jpg';
import ticTacToe2 from '../../assets/images/school-courses/人工智能遊戲編程課程/student-work/student-work-2.jpg';
import pacman from '../../assets/images/school-courses/人工智能遊戲編程課程/student-work/student-work-3.jpg';
import sudoku from '../../assets/images/school-courses/人工智能遊戲編程課程/student-work/student-work-4.jpg';
import minesweeper from '../../assets/images/school-courses/人工智能遊戲編程課程/student-work/student-work-5.jpg';
import chinesePuzzleDemo from '../../assets/images/school-courses/人工智能遊戲編程課程/student-work/chinese-puzzle-demo.png';
import aiGeneratedCodeImage from '../../assets/images/school-courses/人工智能遊戲編程課程/ai_generated_code1_Main.jpg';
import aiGameCodingHero from '../../assets/images/school-courses/人工智能遊戲編程課程/ai-game-coding-hero.jpg';

// Course data (static) - now in frontmatter
export const courseData = {
  title: "人工智能遊戲編程課程",
  subtitle: "以 Gemini + GitHub 學習新世代 Vibe Coding",
  tags: ["AI 人工智能", "Programming 編程", "遊戲開發","初中", "高中"],
  videoId: "your-video-id-here",
  description: "透過 Gemini 以自然語言協作編程，從五子棋原型到個人網頁遊戲開發，並以 GitHub 發佈作品。",
  detailedDescription: "本課程以 Vibe Coding 為核心，學生會學習如何用自然語言與 Gemini 協作，將想法拆解成可實作的遊戲功能。課程由五子棋挑戰開始，逐步完成專案企劃、核心框架、邏輯深化與最終測試，最後透過 GitHub 建立儲存庫、上傳程式碼並啟用 GitHub Pages，讓作品以專屬 URL 對外分享。",
  heroImage: aiGameCodingHero
};

// Course curriculum
const curriculumItems = [
  {
    title: "AI Coding 入門：五子棋挑戰",
    content: [
      "討論遊戲本質（勝利條件、平衡性）",
      "學習如何把規則清楚描述給 AI",
      "使用 Gemini 生成單機版五子棋 HTML 原型",
      "要求 AI 加入難度選擇與 UI 美化"
    ]
  },
  {
    title: "專案企劃：創意發想環節",
    content: [
      "構思並創作屬於自己的項目",
      "觀察經典小遊戲（打磚塊、貪食蛇、2048、心理測驗）並分析適合網頁呈現的玩法",
      "撰寫遊戲說明書（玩家移動、分數計算、死亡機制等）",
      "與 Gemini 討論技術難點與實作建議"
    ]
  },
  {
    title: "專案實作（一）：核心框架",
    content: [
      "生成遊戲主要畫面與基本操作",
      "觀察遊戲行為並向 AI 反饋錯誤進行修改"
    ]
  },
  {
    title: "專案實作（二）：邏輯深度化",
    content: [
      "豐富規則（計分系統、多重關卡或遊戲結束機制）",
      "處理出現的 Bug（邏輯除錯練習）"
    ]
  },
  {
    title: "專案實作（三）：最終測試",
    content: [
      "功能完善（加入最高分紀錄等細節功能）",
      "最終測試（完整系統測試與穩定度除錯）"
    ]
  },
  {
    title: "GitHub 發佈與成果分享",
    content: [
      "建立儲存庫（Repository）與上傳程式碼",
      "啟動 GitHub Pages 取得個人專屬遊戲 URL",
      "作品介紹、互相試玩與評分"
    ]
  }
];

// Course highlights
const courseHighlights = [
  {
    icon: "fas fa-robot",
    title: "Gemini 協作編程",
    description: "以自然語言與 Gemini 協作，把想法快速轉化為可測試的遊戲原型"
  },
  {
    icon: "fas fa-gamepad",
    title: "從原型到完整專案",
    description: "由五子棋起步，逐步完成企劃、框架、規則深化與最終測試，建立完整開發流程"
  },
  {
    icon: "fas fa-lightbulb",
    title: "提示工程與邏輯拆解",
    description: "重視早期思考與需求拆解，培養學生把問題轉化為有效 AI 指令的能力"
  },
  {
    icon: "fas fa-users",
    title: "創意與協作學習",
    description: "透過作品展示與互評，培養創意表達、溝通與持續改進能力"
  },
  {
    icon: "fas fa-globe",
    title: "GitHub 發佈能力",
    description: "學習使用 GitHub 管理與發佈專案，讓同學可透過專屬網址直接試玩作品"
  }
];

// Course requirements
const courseRequirements = [
  {
    icon: "fas fa-clock",
    title: "課時",
    description: "12 小時"
  },
  {
    icon: "fas fa-laptop",
    title: "所需設備",
    description: "手提電腦或桌面電腦或平板電腦"
  },
  {
    icon: "fas fa-user-graduate",
    title: "學員要求",
    description: "中一至中六"
  },
  {
    icon: "fas fa-sign-in-alt",
    title: "帳戶需求",
    description: "Google account 用於登入 GitHub"
  }
];

// FAQ items
const faqItems = [
  {
    question: "零基礎學生可以參加嗎？",
    answer: "完全可以！本課程專為零基礎學生設計，使用 AI 工具讓編程變得簡單易懂。"
  },
  {
    question: "需要自備電腦嗎？",
    answer: "是的，學校需要自備手提電腦，並確保有穩定的網絡連接。"
  },
  {
    question: "會學到什麼編程語言？",
    answer: "主要會接觸 HTML、CSS、JavaScript，並重點學習如何透過自然語言與 Gemini 協作完成程式開發。"
  },
  {
    question: "課程結束後能做出什麼作品？",
    answer: "學生會完成五子棋原型與個人化網頁遊戲，並透過 GitHub Pages 發佈成可分享的作品連結。"
  }
];


---

<Layout title={courseData.title} description={courseData.description}>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  
  <HeroSection 
    title={courseData.title}
    subtitle={courseData.subtitle}
    tags={courseData.tags}
    heroImage={courseData.heroImage}
    description={courseData.detailedDescription}
  />

  <!-- Hero image and description section -->
  <section class="section-padding bg-white">
    <div class="container-standard">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-left lg:pl-4">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">為什麼選擇 AI 編程？</h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            在 AI 原生時代，學生需要的不只是語法知識，更是把想法清楚表達、快速驗證與持續改良的能力。本課程以 Gemini 協作開發為主軸，讓學生在遊戲專案中掌握提示工程、邏輯拆解與除錯流程，並建立可展示的實作成果。
          </p>
          <div class="space-y-4">
            <div class="flex items-start space-x-3">
              <i class="fas fa-check-circle text-brand-cyan-600 mt-1"></i>
              <span class="text-gray-700">以自然語言降低入門門檻，專注創意實現</span>
            </div>
            <div class="flex items-start space-x-3">
              <i class="fas fa-check-circle text-brand-cyan-600 mt-1"></i>
              <span class="text-gray-700">建立需求拆解與提示工程能力</span>
            </div>
            <div class="flex items-start space-x-3">
              <i class="fas fa-check-circle text-brand-cyan-600 mt-1"></i>
              <span class="text-gray-700">完成 GitHub 發佈與成果分享</span>
            </div>
          </div>
        </div>
        <div class="justify-self-start">
          <div class="rounded-lg overflow-hidden shadow-lg mr-auto">
            <Image 
              src={aiGeneratedCodeImage} 
              alt="AI 編程新時代" 
              width={600}
              height={400}
              class="w-full h-auto"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why the technology is important section -->
  <section class="section-padding bg-gray-50">
    <div class="container-standard">
      <h2 class="text-3xl font-bold text-center mb-12 text-gray-800">為什麼選用 Gemini + GitHub？</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="card-base card-hover p-6">
          <div class="flex items-center mb-4">
            <div class="w-8 h-8 bg-brand-cyan-600 rounded-full flex items-center justify-center mr-3">
              <i class="fas fa-brain text-sm text-white"></i>
            </div>
            <h3 class="text-xl font-semibold text-gray-800">Gemini 助手</h3>
          </div>
          <p class="text-gray-600">
            Gemini 能協助學生快速生成原型、釐清邏輯與修正錯誤，讓編程從「記語法」轉向「解決問題」。
          </p>
        </div>
        
        <div class="card-base card-hover p-6">
          <div class="flex items-center mb-4">
            <div class="w-8 h-8 bg-brand-cyan-600 rounded-full flex items-center justify-center mr-3">
              <i class="fas fa-cloud text-sm text-white"></i>
            </div>
            <h3 class="text-xl font-semibold text-gray-800">GitHub 協作與發佈</h3>
          </div>
          <p class="text-gray-600">
            透過 GitHub 建立儲存庫與版本管理，再用 GitHub Pages 發佈，學生可以擁有可公開分享的作品網址。
          </p>
        </div>
        
        <div class="card-base card-hover p-6">
          <div class="flex items-center mb-4">
            <div class="w-8 h-8 bg-brand-cyan-600 rounded-full flex items-center justify-center mr-3">
              <i class="fas fa-gamepad text-sm text-white"></i>
            </div>
            <h3 class="text-xl font-semibold text-gray-800">網頁遊戲開發</h3>
          </div>
          <p class="text-gray-600">
            網頁遊戲無需安裝即可跨裝置執行，適合短時間完成迭代與展示。學生能在實作中同時學習產品思維與程式邏輯。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Course requirements section -->
  <section class="section-padding bg-white">
    <div class="container-standard">
      <h2 class="text-3xl font-bold text-center mb-12 text-gray-800">課程要求</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {courseRequirements.map((requirement) => (
          <div class="card-base card-hover p-6 text-center">
            <div class="w-12 h-12 bg-brand-cyan-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <i class={`${requirement.icon} text-xl text-white`}></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2">{requirement.title}</h3>
            <p class="text-gray-600">{requirement.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Course highlights section -->
  <section class="section-padding bg-gray-50">
    <div class="container-standard">
      <h2 class="text-3xl font-bold text-center mb-12 text-gray-800">課程重點</h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        {courseHighlights.map((highlight) => (
          <div class="card-base card-hover p-6">
            <div class="flex items-center mb-4">
              <div class="w-8 h-8 bg-brand-cyan-600 rounded-full flex items-center justify-center mr-3">
                <i class={`${highlight.icon} text-sm text-white`}></i>
              </div>
              <h3 class="text-lg font-semibold text-gray-800">{highlight.title}</h3>
            </div>
            <p class="text-gray-600">{highlight.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

        <!-- Student Work Showcase section -->
      <section class="section-padding bg-white">
        <div class="container-standard">
          <h2 class="text-3xl font-bold text-center mb-8 text-gray-800">學生作品展示</h2>
          <p class="text-lg text-gray-600 text-center mb-12 max-w-3xl mx-auto">
            點擊下方作品直接試玩學生們在 AI 遊戲編程課程中創作的精彩遊戲！從經典的井字棋到創新的自製遊戲，每個作品都展現了學生們的創意和編程技能。
          </p>

          <a
            href="https://alanchan246.github.io/AI_Vibe_Coding/showcase/index.html"
            target="_blank"
            rel="noopener noreferrer"
            class="block card-base card-hover p-8 mb-12 border-2 border-brand-cyan-200 bg-gradient-to-r from-brand-cyan-50 to-white"
          >
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 bg-brand-cyan-600 rounded-full flex items-center justify-center shrink-0">
                    <i class="fas fa-rocket text-white"></i>
                  </div>
                  <span class="text-sm font-medium text-brand-cyan-700">學友社工作坊</span>
                </div>
                <h3 class="text-xl font-semibold text-gray-800 mb-2">學友社青年 AI Vibe Coding 工作坊 · 作品展示</h3>
                <p class="text-gray-600">
                  同學網頁小遊戲作品集：遊戲大廳、桌遊小站、休閒遊戲館與多款單一遊戲（五子棋、數獨、踩地雷、貪食蛇等），可直接在瀏覽器試玩。
                </p>
              </div>
              <span class="inline-flex items-center justify-center px-6 py-3 bg-brand-cyan-600 text-white font-semibold rounded-lg shrink-0">
                進入作品大廳
                <i class="fas fa-external-link-alt ml-2 text-sm"></i>
              </span>
            </div>
          </a>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Wooden Tic-tac-toe Game -->
            <a href="/games/ai-game-coding/WoodenTicTac/index.html" target="_blank" class="card-base card-hover cursor-pointer">
              <div class="aspect-w-16 aspect-h-9 bg-gray-100">
                <Image 
                  src={ticTacToe1} 
                  alt="木製井字棋遊戲作品" 
                  width={400}
                  height={300}
                  class="w-full h-48 object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">木製井字棋遊戲</h3>
                <p class="text-gray-600 text-sm">具有木製質感的經典井字棋遊戲，結合傳統與現代設計</p>
              </div>
            </a>

            <!-- Tic-tac-tactics Game -->
            <a href="/games/ai-game-coding/TicTacTactics/index.html" target="_blank" class="card-base card-hover cursor-pointer">
              <div class="aspect-w-16 aspect-h-9 bg-gray-100">
                <Image 
                  src={ticTacToe2} 
                  alt="井字棋戰術遊戲作品" 
                  width={400}
                  height={300}
                  class="w-full h-48 object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">井字棋戰術遊戲</h3>
                <p class="text-gray-600 text-sm">加入戰術元素的創新井字棋，考驗策略思維</p>
              </div>
            </a>

            <!-- Sudoku Game -->
            <a href="/games/ai-game-coding/SudokuMaster/index.html" target="_blank" class="card-base card-hover cursor-pointer">
              <div class="aspect-w-16 aspect-h-9 bg-gray-100">
                <Image 
                  src={sudoku} 
                  alt="數獨遊戲作品" 
                  width={400}
                  height={300}
                  class="w-full h-48 object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">數獨大師</h3>
                <p class="text-gray-600 text-sm">經典數獨遊戲的完整實現，包含提示功能和難度等級</p>
              </div>
            </a>
            
            <!-- Minesweeper Game -->
            <a href="/games/ai-game-coding/MinefieldChallenge/index.html" target="_blank" class="card-base card-hover cursor-pointer">
              <div class="aspect-w-16 aspect-h-9 bg-gray-100">
                <Image 
                  src={minesweeper} 
                  alt="踩地雷遊戲作品" 
                  width={400}
                  height={300}
                  class="w-full h-48 object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">踩地雷挑戰</h3>
                <p class="text-gray-600 text-sm">經典踩地雷遊戲的網頁版本，考驗邏輯思維能力</p>
              </div>
            </a>

            <!-- Pac-Man Game -->
            <a href="/games/ai-game-coding/PacManChase/index.html" target="_blank" class="card-base card-hover cursor-pointer">
              <div class="aspect-w-16 aspect-h-9 bg-gray-100">
                <Image 
                  src={pacman} 
                  alt="食鬼遊戲作品" 
                  width={400}
                  height={300}
                  class="w-full h-48 object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">食鬼追逐遊戲</h3>
                <p class="text-gray-600 text-sm">經典食鬼遊戲的重新詮釋，展現動畫和遊戲邏輯的結合</p>
              </div>
            </a>

            <!-- Chinese Puzzle Game -->
            <a href="/games/ai-game-coding/ChinesePuzzle/index.html" target="_blank" class="card-base card-hover cursor-pointer">
              <div class="aspect-w-16 aspect-h-9 bg-gray-100">
                <Image 
                  src={chinesePuzzleDemo} 
                  alt="中國拼圖遊戲作品" 
                  width={400}
                  height={300}
                  class="w-full h-48 object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">中國拼圖遊戲</h3>
                <p class="text-gray-600 text-sm">傳統中國益智遊戲的現代化實現，學習成語和中文</p>
              </div>
            </a>
          </div>



      <!-- Student Testimonials -->
      <div class="mt-16 bg-gray-50 rounded-lg p-8">
        <h3 class="text-2xl font-bold text-gray-800 mb-6 text-center">學生心得分享</h3>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="card-base p-6">
            <div class="flex items-center mb-4">
              <i class="fas fa-quote-left text-2xl text-brand-cyan-600 mr-3"></i>
              <h4 class="text-lg font-semibold text-gray-800">AI 編程初體驗</h4>
            </div>
            <p class="text-gray-600 italic">
              "沒想到編程可以這麼有趣！使用 AI 工具幫助我設計遊戲邏輯，讓我能專注在創意上。完成第一個井字棋遊戲時，那種成就感真的很棒！"
            </p>
          </div>
          <div class="card-base p-6">
            <div class="flex items-center mb-4">
              <i class="fas fa-quote-left text-2xl text-brand-cyan-600 mr-3"></i>
              <h4 class="text-lg font-semibold text-gray-800">從零到一的突破</h4>
            </div>
            <p class="text-gray-600 italic">
              "作為編程新手，這個課程讓我學會了如何與 AI 協作開發。現在我不僅能製作遊戲，還能將作品分享給朋友們玩，真的很興奮！"
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Content Section -->
  <SingleCourseContent 
    items={curriculumItems}
    hours="12 小時"
  />

  <QnASection faqs={faqItems} />
  <!-- Related Courses Section -->
  <RelatedCourses courseTags={courseData.tags} courseTitle={courseData.title} currentCourseSlug="ai-game-coding" context="course" />
  <!-- Related News Section -->
  <RelatedNews courseTags={courseData.tags} courseTitle={courseData.title} />



  <!-- Contact section -->
  <ContactSection subtitle="想了解更多關於 AI Vibe Coding（Gemini + GitHub）課程的資訊？歡迎聯絡我們，我們會提供詳細的課程安排與報名資訊。" />
</Layout>



