    ]
  },
  {
    title: "製作個人故事繪本（2）",
    content: [
      "使用 Gemini 生成插畫（10 頁連封面）",
      "設計主角形象",
      "對角色外觀進行局部調整及如何保持外觀一致"
    ]
  },
  {
    title: "製作個人故事繪本（3）",
    content: [
      "Canva 實用功能介紹",
      "了解各種繪本排版手法",
      "使用 Canva 為繪本進行排版",
      "基礎的排版、字體選擇、顏色協調"
    ]
  },
  {
    title: "製作個人故事繪本（4）",
    content: [
      "為個人作品進行排版",
      "基本匯報技巧",
      "進行簡單作品分享"
    ]
  }
];

// Course curriculum - Comic / picture book track
const advancedCurriculum = [
  {
    title: "了解 AI 生成工具 Gemini",
    content: [
      "認識什麼是 AI 藝術創作",
      "認識 Gemini 對話式 AI 平台",
      "基本提示詞技巧",
      "AI 資訊素養"
    ]
  },
  {
    title: "Nano Banana 基本操作",
    content: [
      "認識 Nano Banana 圖像生成平台",
      "練習用生成指定圖片"
    ]
  },
  {
    title: "了解學習不同繪畫風格及角度",
    content: [
      "認識不同的圖像風格",
      "理解不同的作品所需要的圖像尺寸及比例",
      "為作品設定合適的提示詞"
    ]
  },
  {
    title: "以 Gemini 構思四格漫畫／故事繪本大綱",
    content: [
      "了解漫畫／故事繪本是由不同「鏡頭／畫面」組成的概念（簡單分鏡）",
      "利用 AI 將故事拆解成連續場景",
      "學習指示 AI 幫忙寫出每個場景的畫面描述（提示詞）"
    ]
  },
  {
    title: "故事插圖設計（1）：設計故事人物",
    content: [
      "學習如何設定主角的外貌特徵、服裝與畫風（如 3D 卡通、水彩繪本風）",
      "運用 Gemini 生成故事主角的「角色參考圖」並學習儲存備用"
    ]
  },
  {
    title: "故事插圖設計（2）：融合背景及角色圖像",
    content: [
      "將準備好的場景描述輸入 Gemini，生成場景圖",
      "學習修改圖片比例（如改為橫向 16:9 適合影片播放）",
      "導師從旁協助學生解決「咒語」不準確或圖片出錯的問題"
    ]
  },
  {
    title: "Canva 基本操作及排版",
    content: [
      "認識 Canva 的編輯介面，開啟空白專案",
      "將 Gemini 生成的圖片匯入，並按故事發展順序排列在正確的頁面上",
      "學習使用文字工具，為作品加上簡單易讀的故事字幕或標題"
    ]
  }
];

// Course arrangement
const courseArrangement = [
  {
    icon: "fas fa-star",
    title: "STEM Day 活動",
    description: ""
  },
  {
    icon: "fas fa-star",
    title: "完整課程 (2-10 小時)",
    description: "可按學校需要選擇模組與時數，靈活安排課堂。*可根據學校需要調整課堂數及時數"
  }
];

// FAQ section
const faqItems = [
  {
    question: "什麽年級的學生適合？",
    answer: [
      "該課程一般適合任何初小至初中學生。",
      "如學生具備基本電腦操作更好 （如打字）。"
    ]
  },
  {
    question: "學校需要甚麽設備？",
    answer: [
      "學校需準備以下項目",
      "1）iPad／手提電腦／桌面電腦",
      "2）學生 Google 帳號（以登入 Gemini 及 Canva）",
      "建議先致電 +852 6554-1506 或電郵至 info@10botics.com 向同事溝通學校期望的教學內容，同事將就教學所需設備提供建議。"
    ]
  }
];

// Course highlights
const courseHighlights = [
  {
    icon: "fas fa-palette",
    title: "AI 藝術創作",
    description: "學習使用 Gemini 與 Nano Banana 圖像生成，透過提示詞創作賀卡、漫畫與插畫"
  },
  {
    icon: "fas fa-book",
    title: "故事繪本製作",
    description: "以 Gemini 構思故事與生成插畫，配合 Canva 完成排版與作品分享"
  },
  {
    icon: "fas fa-language",
    title: "跨學科學習",
    description: "整合語文、視覺藝術、電腦科等多個學科，培養綜合能力"
  },
  {
    icon: "fas fa-users",
    title: "協作與展示",
    description: "與同學合作創作，並進行成果匯報，提升表達能力"
  }
];
---

<Layout title={courseData.title} description={courseData.description}>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  
  <main>
    <!-- Hero Section -->
    <HeroSection 
      title={courseData.title}
      subtitle={courseData.subtitle}
      description={courseData.detailedDescription}
      heroImage={courseData.heroImage}
      tags={courseData.tags}
    />

    <!-- Cross-disciplinary Learning Section -->
    <section class="section-padding bg-gray-50">
      <div class="container-standard">
        <h2 class="text-3xl font-bold text-center mb-12 text-gray-800">跨學科學習</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {crossDisciplinaryLearning.map((item) => (
            <div class="card-base card-hover p-6 text-center">
              <div class="text-4xl text-brand-cyan-600 mb-4">
                <i class={item.icon}></i>
              </div>
              <h3 class="text-xl font-semibold text-gray-800 mb-3">{item.title}</h3>
              <p class="text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Course Content Section -->
    <DualCourseContent 
      beginnerTitle="AI藝術創作課程"
      advancedTitle="AI 四格漫畫／故事繪本課程"
      beginnerItems={beginnerCurriculum}
      advancedItems={advancedCurriculum}
      beginnerHours="2-10 小時"
      advancedHours="5-10 小時"
    />

    <!-- Course Arrangement Section -->
    <section class="section-padding bg-gray-50">
      <div class="container-standard">
        <h2 class="text-3xl font-bold text-center mb-12 text-gray-800">課程安排</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {courseArrangement.map((item) => (
            <div class="card-base card-hover p-6">
              <div class="flex items-center mb-4">
                <div class="w-8 h-8 bg-semantic-warning rounded-full flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-800">{item.title}</h3>
              </div>
              {item.description && <p class="text-gray-600 whitespace-pre-line">{item.description}</p>}
            </div>
          ))}
        </div>
        
        <div class="text-center mt-8">
          <p class="text-gray-600">歡迎填妥下方表格讓同事為你提供咨詢。</p>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <QnASection faqs={faqItems.map(item => ({
      question: item.question,
      answer: item.answer.join('\n')
    }))} />

    <!-- Related Courses Section -->
    <RelatedCourses courseTags={courseData.tags} courseTitle={courseData.title} currentCourseSlug="ai-enrichment-course" context="course" />
    <!-- Related News Section -->
    <RelatedNews courseTags={courseData.tags} courseTitle={courseData.title} />

    <!-- Contact Section -->
    <ContactSection subtitle="想了解更多關於 AI 藝術創作課程的資訊？歡迎聯絡我們，我們會為您提供詳細的課程安排和報名資訊。" />
  </main>
</Layout> 
