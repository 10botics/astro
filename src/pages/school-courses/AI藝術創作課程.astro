---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import DualCourseContent from '../../components/course/DualCourseContent.astro';
import QnASection from '../../components/course/QnASection.astro';
import ContactSection from '../../components/ContactSection.astro';
import RelatedNews from '../../components/course/RelatedNews.astro';
import RelatedCourses from '../../components/course/RelatedCourses.astro';
import { Image } from 'astro:assets';

// Import course image
import featuredImage from '../../assets/images/school-courses/AI啟蒙課程/ai-story-creation.png';

// Course data
export const courseData = {
  title: "AI藝術創作課程",
  subtitle: "探索人工智能在視覺藝術領域的應用及創作",
  tags: ["AI 人工智能", "Arts 藝術", "Google Gemini", "初小", "高小", "初中"],
  videoId: "your-video-id-here",
  description: "探索 AI 在視覺藝術領域的應用，學習 Gemini 與 Nano Banana 圖像生成，配合 Canva 完成賀卡、四格漫畫與故事繪本，培養創意表達能力。適合初小至初中學生。",
  detailedDescription: "課程引導學生探索人工智能在視覺藝術領域的應用。學生將認識 Gemini 對話式 AI 與 Nano Banana 圖像生成，學習提示詞技巧與 AI 資訊素養，並透過節日賀卡、旅遊日誌圖、四格漫畫等專題累積創作經驗；進階可完成個人故事繪本，以 Canva 排版並進行作品分享。",
  heroImage: featuredImage
};

// Cross-disciplinary learning highlights
const crossDisciplinaryLearning = [
  {
    icon: "fas fa-book-reader",
    title: "價值教育",
    description: "透過不同主題配合學校重點培養的價值觀和態度，例如使用中國詩詞/故事作主題以增強學生的國民身份認同。"
  },
  {
    icon: "fas fa-highlighter",
    title: "語文科",
    description: "在創作AI生成作品時，學生需要就主題輸入各種中/英文文字指令，訓練學生對字詞及文字表達的能力。"
  },
  {
    icon: "fas fa-file-image",
    title: "視覺藝術科",
    description: "AI圖像生成過程中會學習各種藝術風格、筆觸等和視藝有關的知識，讓學生可從嶄新的角度接觸藝術，激發創意。"
  },
  {
    icon: "fas fa-robot",
    title: "電腦科",
    description: "引導學生探索人工智能的基本知識及各種應用，培養學生對科技的興趣。"
  }
];

// Course curriculum - AI art creation track
const beginnerCurriculum = [
  {
    title: "Gemini AI",
    content: [
      "了解 AI 生成工具 Gemini",
