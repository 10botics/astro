---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/course/HeroSection.astro';
import SingleCourseContent from '../../components/course/SingleCourseContent.astro';
import QnASection from '../../components/course/QnASection.astro';
import ContactSection from '../../components/ContactSection.astro';
import RelatedNews from '../../components/course/RelatedNews.astro';
import RelatedCourses from '../../components/course/RelatedCourses.astro';

import heroImage from '../../assets/images/school-courses/AI影片製作課程/manga-to-color-hero.png';

export const courseData = {
  title: "人工智能媒體創作課程",
  subtitle: "以 Cursor 與 AI 工具，從黑白漫畫創意到彩色動畫影片",
  tags: [
    "AI 人工智能",
    "Video 影片製作",
    "Animation 動畫",
    "Programming 編程",
    "Creative 創意",
    "初中",
    "高中"
  ],
  videoId: "your-video-id-here",
  description:
    "透過 Cursor 人工智能編程平台及現實世界中的黑白漫畫作引子，學習用 AI 製作一段彩色影片。學生將掌握人工智能編程概念、圖像元素創建、動畫設計和影片剪輯等技巧。",
  detailedDescription:
    "這個課程將帶領學生透過 Cursor 人工智能編程平台及現實世界中的黑白漫畫作引子，學習用 AI 製作一段彩色影片。學生將學會人工智能編程概念、創建圖像元素、動畫設計和影片剪輯等技巧，最終會先一起完成一個測試作品，及後學生將有機會學以致用，製作屬於自己／自定義主題的作品。",
  heroImage
};

const courseRequirements = [
  {
    icon: "fas fa-clock",
    title: "課時",
    description: "12–18 小時"
  },
  {
    icon: "fas fa-laptop",
    title: "所需器材",
    description: "電腦；Cursor 訂閱帳戶（如學校沒有可由 10 教育提供帳戶於課堂上使用）"
  },
  {
    icon: "fas fa-user-graduate",
    title: "學員要求",
    description: "中二至中四；基本電腦操作（如打字、登入系統等）"
  }
];

const courseFeatures = [
  {
    icon: "fas fa-code",
    title: "Cursor AI 編程平台",
    description: "透過 Cursor 學習人工智能編程概念，把創意想法轉化為可執行的媒體製作流程"
  },
  {
    icon: "fas fa-book-open",
    title: "黑白漫畫到彩色影片",
    description: "以現實世界黑白漫畫為引子，逐步學習用 AI 創建圖像元素並製作彩色動畫短片"
  },
  {
    icon: "fas fa-film",
    title: "專業製作流程",
    description: "從鏡頭清單、參考幀、關鍵劇照到音訊資產與時間軸預演，建立完整的媒體創作方法"
  },
  {
    icon: "fas fa-project-diagram",
    title: "測試作品與個人專題",
    description: "先共同完成測試作品，再學以致用製作屬於自己／自定義主題的專題作品"
  }
];

const courseCurriculum = [
  {
    title: "故事順序、鏡頭、視覺鎖定與聲音計畫",
    content: [
      "確立故事順序與節奏點（beats）",
      "建立包含固定 ID 和螢幕備註的鏡頭清單（shot list）",
      "記錄畫面的連貫性並製作一份簡明的風格指南",
      "添加音訊計畫：旁白（VO）腳本或逐個節奏點的台詞",
      "為每個節奏點／鏡頭列出音效（SFX）提示清單",
      "制定背景音樂指導（情緒、節奏、能量，以及音樂應該高昂或減弱的位置）"
    ]
  },
  {
    title: "每個鏡頭的參考幀（畫面 + 聲音對點）",
    content: [
      "根據計畫的場景調度，為每個鏡頭準備一張參考圖",
      "使用與鏡頭 ID 相對應的命名",
      "在進行大量圖像生成之前，對參考圖的構圖、順序和細節進行品質控管（QC）",
      "添加聲音對點／定位（spotting）備註：明確旁白、音效和音樂的變化點應落在各個鏡頭的哪個相對位置"
    ]
  },
  {
    title: "關鍵劇照、旁白／音效／音樂資產與審核",
    content: [
      "根據參考圖和風格指南，為每個鏡頭製作一張主劇照",
      "挑選出審核通過的關鍵圖（heroes），並重做明顯不合格的圖像",
      "獲取旁白（如合成語音），並匯出按鏡頭／台詞標記的分軌（stems）",
      "為清單上的提示點製作或尋找音效素材",
      "選擇或生成符合專案要求的背景音樂"
    ]
  },
  {
    title: "劇照生成短動態影片 + 臨時音訊預演",
    content: [
      "使用審核通過的劇照生成短動態片段，配合簡短的運動提示詞並進行簡單的版本控制",
      "進行粗略的時間軸排版：將旁白、音效、音樂與動態畫面齊平",
      "在簡單的專案或草稿時間軸中預演，以便儘早暴露問題",
      "修復明顯的音畫同步或音量電平（level）問題"
    ]
  },
  {
    title: "專題製作",
    content: [
      "創作個人專題作品"
    ]
  }
];

const faqItems = [
  {
    question: "什麼年級的學生適合？",
    answer: [
      "本課程適合中二至中四學生。",
      "學生需具備基本電腦操作能力，例如打字及登入系統。"
    ]
  },
  {
    question: "學校需要什麼設備？",
    answer: [
      "學校需準備以下項目：",
      "1）電腦",
      "2）Cursor 訂閱帳戶（如學校沒有，可由 10 教育於課堂上提供帳戶）",
      "3）穩定的網絡連接",
      "建議先致電 +852 6554-1506 或電郵至 info@10botics.com 向同事溝通學校期望的教學內容，我們將就設備與帳戶安排提供建議。"
    ]
  },
  {
    question: "課程會使用哪些工具？",
    answer: [
      "課程以 Cursor 人工智能編程平台為核心，配合 AI 圖像生成、動畫製作與影片剪輯相關工具。",
      "學生將從黑白漫畫創意出發，完成鏡頭規劃、視覺資產製作、音訊整合與最終短片輸出。"
    ]
  },
  {
    question: "學生需要具備什麼基礎？",
    answer: [
      "學生需要具備：",
      "• 基本電腦操作能力（如打字、登入系統）",
      "• 對故事創作與影片製作有興趣",
      "• 願意按步驟完成鏡頭規劃、資產審核與時間軸預演等製作流程"
    ]
  }
];
---

<Layout title={courseData.title} description={courseData.description}>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

  <main>
    <HeroSection
      title={courseData.title}
      subtitle={courseData.subtitle}
      description={courseData.detailedDescription}
      heroImage={courseData.heroImage}
      tags={courseData.tags}
    />

    <section class="section-padding bg-white">
      <div class="container-standard">
        <h2 class="text-3xl font-bold text-center mb-12 text-gray-800">課程要求</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {courseRequirements.map((requirement) => (
            <div class="card-base card-hover p-6 text-center">
              <div class="w-12 h-12 bg-brand-cyan-600 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class={`${requirement.icon} text-xl text-white`}></i>
              </div>
              <h3 class="text-lg font-semibold text-gray-800 mb-2">{requirement.title}</h3>
              <p class="text-gray-600">{requirement.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding bg-gray-50">
      <div class="container-standard">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">課程特色</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {courseFeatures.map((item) => (
            <div class="card-base card-hover p-6">
              <div class="flex items-start">
                <div class="text-3xl text-brand-cyan-600 mr-4">
                  <i class={item.icon}></i>
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 mb-3">{item.title}</h3>
                  <p class="text-gray-600">{item.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SingleCourseContent
      items={courseCurriculum}
      hours="12–18 小時"
    />

    <QnASection faqs={faqItems.map((item) => ({
      question: item.question,
      answer: item.answer.join('\n')
    }))} />

    <RelatedCourses
      courseTags={courseData.tags}
      courseTitle={courseData.title}
      currentCourseSlug="ai-video-production"
      context="course"
    />

    <RelatedNews courseTags={courseData.tags} courseTitle={courseData.title} />

    <ContactSection subtitle="想了解更多關於人工智能媒體創作課程的資訊？歡迎聯絡我們，我們會為您提供詳細的課程安排和報名資訊。" />
  </main>
</Layout>
