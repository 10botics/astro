---
import { Image, type ImageMetadata } from 'astro:assets';

export type GalleryImageInput =
  string | ImageMetadata | { src: string | ImageMetadata; alt: string };

type NormalizedGalleryImage = {
  src: string | ImageMetadata;
  alt: string;
  isRemote: boolean;
};

export interface Props {
  title?: string;
  /** Use `null`/`undefined` entries to keep slide positions; they reuse the first valid image. */
  images: ReadonlyArray<GalleryImageInput | null | undefined>;
  intervalMs?: number;
}

/** Vite/Astro metadata: `src` may be a string or URL object — requiring `typeof src === 'string'` caused null slides. */
function isImageMetadataLike(o: Record<string, unknown>): boolean {
  return (
    typeof o.width === 'number' &&
    typeof o.height === 'number' &&
    typeof o.format === 'string' &&
    'src' in o &&
    o.src != null
  );
}

function normalizeGalleryImage(
  img: GalleryImageInput | null | undefined,
): NormalizedGalleryImage | null {
  if (img == null) {
    return null;
  }
  if (typeof img === 'string') {
    return { src: img, alt: 'Gallery image', isRemote: true };
  }
  if (img && typeof img === 'object') {
    const o = img as Record<string, unknown>;
    // Dynamic `import("./asset.jpg")` gives `{ default: ImageMetadata }` — unwrap before other checks.
    if (
      'default' in o &&
      (o.default as unknown) !== null &&
      (o.default as unknown) !== undefined &&
      !isImageMetadataLike(o)
    ) {
      return normalizeGalleryImage(o.default as GalleryImageInput);
    }
    if (isImageMetadataLike(o)) {
      return { src: img as ImageMetadata, alt: 'Gallery image', isRemote: false };
    }
    if ('src' in o && o.src !== undefined) {
      const alt = typeof o.alt === 'string' ? o.alt : 'Gallery image';
      const sub = o.src;
      if (typeof sub === 'string') {
        return { src: sub, alt, isRemote: true };
      }
      if (sub instanceof URL) {
        return { src: sub.href, alt, isRemote: true };
      }
      if (sub && typeof sub === 'object') {
        const m = sub as Record<string, unknown>;
        if (isImageMetadataLike(m)) {
          return { src: sub as ImageMetadata, alt, isRemote: false };
        }
      }
    }
  }
  return null;
}

const { title, images: imagesRaw, intervalMs = 4000 } = Astro.props;
const images = imagesRaw ?? [];

// Normalize images for string URLs, ImageMetadata imports, or { src, alt } wrappers.
// Entries that fail normalization reuse the first valid image instead of becoming null gaps.
const normalizedSlots = images.map(normalizeGalleryImage);
const firstValidImage =
  normalizedSlots.find((img): img is NormalizedGalleryImage => img !== null);
const normalizedImages: NormalizedGalleryImage[] =
  firstValidImage === undefined
    ? []
    : normalizedSlots.map((slot) => slot ?? firstValidImage);

/** No clones / no “more slides” UX when everything fits the strip (≤3 slides). */
const interactiveCarousel = normalizedImages.length > 3;

// Debug logging for development
if (import.meta.env.DEV) {
  console.log('GalleryCarousel - Original images:', images);
  console.log('GalleryCarousel - Normalized images:', normalizedImages);
}
---

<div
  class="gallery-carousel relative"
  data-interval-ms={intervalMs}
  data-carousel-static={interactiveCarousel ? undefined : 'true'}
>
  {title && (
    <div class="text-center mb-8">
      <h3 class="text-2xl font-bold text-gray-800">{title}</h3>
    </div>
  )}
  
  <div class="relative overflow-hidden">
    {normalizedImages.length > 0 ? (
      <>
        <!-- Carousel Track -->
        <div 
          class="carousel-track flex transition-transform duration-500 ease-in-out"
        >
          {/* Create clones for seamless circular scrolling - clone last few images at beginning */}
          {normalizedImages.length > 3 && normalizedImages.slice(-3).map((img, index) => (
            <div 
              class="carousel-slide flex-shrink-0 w-full lg:w-1/3 md:w-1/2 px-2"
              data-clone="start"
            >
              {img.isRemote ? (
                <img 
                  src={img.src as string} 
                  alt={img.alt}
                  class="w-full h-auto object-contain rounded-lg"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <Image 
                  src={img.src as ImageMetadata} 
                  alt={img.alt}
                  class="w-full h-auto object-contain rounded-lg"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>
          ))}

          {/* Original images */}
          {normalizedImages.map((img, index) => (
            <div 
              class="carousel-slide flex-shrink-0 w-full lg:w-1/3 md:w-1/2 px-2"
              data-original-index={index}
            >
              {img.isRemote ? (
                <img 
                  src={img.src as string} 
                  alt={img.alt}
                  class="w-full h-auto object-contain rounded-lg"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <Image 
                  src={img.src as ImageMetadata} 
                  alt={img.alt}
                  class="w-full h-auto object-contain rounded-lg"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>
          ))}

          {/* Create clones for seamless circular scrolling - clone first few images at end */}
          {normalizedImages.length > 3 && normalizedImages.slice(0, 3).map((img, index) => (
            <div 
              class="carousel-slide flex-shrink-0 w-full lg:w-1/3 md:w-1/2 px-2"
              data-clone="end"
            >
              {img.isRemote ? (
                <img 
                  src={img.src as string} 
                  alt={img.alt}
                  class="w-full h-auto object-contain rounded-lg"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <Image 
                  src={img.src as ImageMetadata} 
                  alt={img.alt}
                  class="w-full h-auto object-contain rounded-lg"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>
          ))}
        </div>

        {interactiveCarousel && (
          <>
            <!-- Navigation Buttons -->
            <button
              type="button"
              class="carousel-btn carousel-prev absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-gray-800 p-2 rounded-full shadow-lg transition-all duration-200 z-10"
              aria-label="Previous image"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
            </button>

            <button
              type="button"
              class="carousel-btn carousel-next absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white text-gray-800 p-2 rounded-full shadow-lg transition-all duration-200 z-10"
              aria-label="Next image"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>

            <!-- Dots -->
            <div class="carousel-dots absolute bottom-4 left-1/2 -translate-x-1/2 flex space-x-2 z-10">
              {normalizedImages.map((_, i) => (
                <button
                  type="button"
                  class="carousel-dot w-3 h-3 rounded-full bg-white/60 hover:bg-white transition-colors duration-200"
                  aria-label={`Go to slide ${i + 1}`}
                  data-index={i}
                ></button>
              ))}
            </div>
          </>
        )}
      </>
    ) : (
      <div class="text-center py-16 text-gray-500">
        <p>No images available</p>
      </div>
    )}
  </div>
</div>

<style>
  .gallery-carousel {
    --per-view: 1;
  }
  
  @media (min-width: 768px) {
    .gallery-carousel {
      --per-view: 2;
    }
  }
  
  @media (min-width: 1024px) {
    .gallery-carousel {
      --per-view: 3;
    }
  }
  
  .carousel-track {
    transform: translateX(0);
  }
</style>

<script>
  class GalleryCarousel {
    private container: HTMLElement;
    private track: HTMLElement;
    private slides: NodeListOf<Element>;
    private originalSlides: NodeListOf<Element>;
    private prevBtn: HTMLElement | null;
    private nextBtn: HTMLElement | null;
    private dots: NodeListOf<Element>;
    private currentIndex: number;
    private perView: number;
    private totalSlides: number;
    private cloneOffset: number;
    private autoplayInterval: ReturnType<typeof setInterval> | null;
    private intervalMs: number;
    /** Full carousel UX (nav, autoplay); off when slide count ≤ 3. */
    private interactive: boolean;

    constructor(container: HTMLElement) {
      this.container = container;
      this.interactive =
        container.getAttribute('data-carousel-static') !== 'true';
      this.track = container.querySelector('.carousel-track') as HTMLElement;
      this.slides = container.querySelectorAll('.carousel-slide');
      this.originalSlides = container.querySelectorAll('[data-original-index]');
      this.prevBtn = container.querySelector('.carousel-prev') as HTMLElement | null;
      this.nextBtn = container.querySelector('.carousel-next') as HTMLElement | null;
      this.dots = container.querySelectorAll('.carousel-dot');
      
      this.totalSlides = this.originalSlides.length;
      this.cloneOffset = this.totalSlides > 3 ? 3 : 0; // Number of cloned slides at the beginning
      this.currentIndex = this.cloneOffset; // Start at the first real slide
      this.perView = this.getPerView();
      this.autoplayInterval = null;
      this.intervalMs = parseInt(container.dataset.intervalMs || '4000');
      
      this.init();
    }

    /** Euclidean modulo: always in [0, n) for n > 0. */
    private mod(slideIndex: number, n: number): number {
      if (n <= 0) return 0;
      return ((slideIndex % n) + n) % n;
    }

    /** Which original slide (0 … n−1) the track position represents. Uses modulo after clone-strip mapping. */
    private getLogicalSlideIndex(): number {
      const n = this.totalSlides;
      if (n === 0) return 0;
      if (this.cloneOffset === 0) {
        return this.mod(this.currentIndex, n);
      }
      let active = this.currentIndex - this.cloneOffset;
      const firstEndClone = this.cloneOffset + n;
      if (this.currentIndex >= firstEndClone) {
        active = this.currentIndex - firstEndClone;
      } else if (this.currentIndex < this.cloneOffset) {
        active = this.currentIndex + n - this.cloneOffset;
      }
      return this.mod(active, n);
    }

    /** Map a logical slide to the physical strip index used by translate (clone band or linear). */
    private physicalFromLogical(logicalSlide: number): number {
      const n = this.totalSlides;
      if (n === 0) return 0;
      const l = this.mod(logicalSlide, n);
      return this.cloneOffset === 0 ? l : this.cloneOffset + l;
    }
    
    getPerView(): number {
      if (window.innerWidth >= 1024) return 3; // lg
      if (window.innerWidth >= 768) return 2;  // md
      return 1; // sm
    }
    
    updatePerView() {
      const newPerView = this.getPerView();
      if (newPerView !== this.perView) {
        this.perView = newPerView;
        if (!this.interactive) {
          this.updateTrack();
          return;
        }
        const logical = this.getLogicalSlideIndex();
        /** Keep same slide visible; modulo maps logical index into correct physical position for new viewport. */
        this.currentIndex = this.physicalFromLogical(logical);
        this.updateTrack();
        this.updateDots();
      }
    }
    
    init() {
      if (!this.interactive) {
        this.perView = this.getPerView();
        this.updateTrack();
        window.addEventListener('resize', () => this.updatePerView());
        return;
      }

      this.bindEvents();
      this.startAutoplay();
      this.updateDots();
      this.updateButtons();
      this.updateTrack();
    }
    
    bindEvents() {
      this.prevBtn?.addEventListener('click', () => this.prev());
      this.nextBtn?.addEventListener('click', () => this.next());
      
      this.dots.forEach((dot: Element, index: number) => {
        dot.addEventListener('click', () => this.goToSlide(index));
      });
      
      // Pause autoplay on hover
      this.container.addEventListener('mouseenter', () => this.pauseAutoplay());
      this.container.addEventListener('mouseleave', () => this.resumeAutoplay());
      
      // Pause autoplay on interaction
      this.container.addEventListener('click', () => this.pauseAutoplay());
      
      // Handle responsive behavior
      window.addEventListener('resize', () => this.updatePerView());
      
      this.track.addEventListener('transitionend', (e) => this.onTrackTransitionEnd(e));
      
      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (this.container.contains(document.activeElement)) {
          if (e.key === 'ArrowLeft') this.prev();
          if (e.key === 'ArrowRight') this.next();
        }
      });
    }
    
    private setTrackTransition(enabled: boolean) {
      this.track.style.transition = enabled ? '' : 'none';
    }

    /** After transform transition: snap from clone strip to equivalent real slide (invisible jump). */
    private onTrackTransitionEnd(e: TransitionEvent) {
      if (e.target !== this.track || e.propertyName !== 'transform') return;
      if (this.cloneOffset === 0) return;

      const n = this.totalSlides;
      const firstEndClone = this.cloneOffset + n;

      if (this.currentIndex >= firstEndClone) {
        this.setTrackTransition(false);
        const logical = this.mod(this.currentIndex - firstEndClone, n);
        this.currentIndex = this.physicalFromLogical(logical);
        this.updateTrack();
        requestAnimationFrame(() => {
          requestAnimationFrame(() => this.setTrackTransition(true));
        });
        this.updateDots();
        return;
      }

      if (this.currentIndex >= 0 && this.currentIndex < this.cloneOffset) {
        this.setTrackTransition(false);
        const logical = this.mod(this.currentIndex + n - this.cloneOffset, n);
        this.currentIndex = this.physicalFromLogical(logical);
        this.updateTrack();
        requestAnimationFrame(() => {
          requestAnimationFrame(() => this.setTrackTransition(true));
        });
        this.updateDots();
      }
    }

    updateTrack() {
      const imageWidth = 100 / this.perView; // Width of one image in the current view
      const translateX = -(this.currentIndex * imageWidth);
      this.track.style.transform = `translateX(${translateX}%)`;
    }
    
    prev() {
      const n = this.totalSlides;
      if (n === 0) return;

      if (this.cloneOffset === 0) {
        this.currentIndex = this.mod(this.currentIndex - 1, n);
        this.updateTrack();
        this.updateDots();
        this.updateButtons();
        this.restartAutoplay();
        return;
      }

      this.currentIndex--;

      if (this.currentIndex < 0) {
        this.setTrackTransition(false);
        /** Left of first cell → previous slide in modulo order (wrap to last logical). */
        this.currentIndex = this.physicalFromLogical(n - 1);
        this.updateTrack();
        requestAnimationFrame(() => {
          requestAnimationFrame(() => this.setTrackTransition(true));
        });
      }

      this.updateTrack();
      this.updateDots();
      this.updateButtons();
      this.restartAutoplay();
    }
    
    next() {
      const n = this.totalSlides;
      if (n === 0) return;

      if (this.cloneOffset === 0) {
        this.currentIndex = this.mod(this.currentIndex + 1, n);
        this.updateTrack();
        this.updateDots();
        this.updateButtons();
        this.restartAutoplay();
        return;
      }

      this.currentIndex++;

      const maxPhy = this.cloneOffset + n + this.cloneOffset - 1;
      if (this.currentIndex > maxPhy) {
        this.setTrackTransition(false);
        /** Read logical from last valid cell, advance one modulo n → first→second wrap at cycle. */
        this.currentIndex--;
        const nextLogical = this.mod(this.getLogicalSlideIndex() + 1, n);
        this.currentIndex = this.physicalFromLogical(nextLogical);
        this.updateTrack();
        requestAnimationFrame(() => {
          requestAnimationFrame(() => this.setTrackTransition(true));
        });
      }

      this.updateTrack();
      this.updateDots();
      this.updateButtons();
      this.restartAutoplay();
    }
    
    goToSlide(slideIndex: number) {
      const n = this.totalSlides;
      if (n === 0) return;
      this.currentIndex = this.physicalFromLogical(slideIndex);
      this.updateTrack();
      this.updateDots();
      this.updateButtons();
      this.restartAutoplay();
    }
    
    updateDots() {
      const n = this.totalSlides;
      if (n === 0) return;
      const clampedDot = this.getLogicalSlideIndex();

      this.dots.forEach((dot: Element, index: number) => {
        if (index === clampedDot) {
          dot.classList.add('bg-white');
          dot.classList.remove('bg-white/60');
          dot.setAttribute('aria-selected', 'true');
        } else {
          dot.classList.remove('bg-white');
          dot.classList.add('bg-white/60');
          dot.setAttribute('aria-selected', 'false');
        }
      });
    }
    
    updateButtons() {
      // Buttons are always enabled for circular navigation
      this.prevBtn?.setAttribute('aria-disabled', 'false');
      this.nextBtn?.setAttribute('aria-disabled', 'false');
    }
    
    startAutoplay() {
      this.autoplayInterval = setInterval(() => {
        this.next();
      }, this.intervalMs);
    }
    
    pauseAutoplay() {
      if (this.autoplayInterval) {
        clearInterval(this.autoplayInterval);
        this.autoplayInterval = null;
      }
    }
    
    resumeAutoplay() {
      setTimeout(() => {
        this.startAutoplay();
      }, 1000);
    }
    
    restartAutoplay() {
      this.pauseAutoplay();
      this.startAutoplay();
    }
  }
  
  // Initialize all carousels
  document.addEventListener('DOMContentLoaded', () => {
    const carousels = document.querySelectorAll('.gallery-carousel');
    carousels.forEach(carousel => {
      new GalleryCarousel(carousel as HTMLElement);
    });
  });
</script> 